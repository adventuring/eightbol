;; src/backend-sm83.lisp — Sharp SM83 (Game Boy) code generation backend
;;
;; The SM83 is the CPU in the Nintendo Game Boy, similar to Z80/8080.
;; Registers: A, B, C, D, E, H, L, BC, DE, HL, SP
;; Instructions: ld, add, sub, and, or, xor, cp, jr, jp, call, ret
;;
;; Output: RGBDS assembly syntax (ld a,[hl], jr nz, etc.)
;; Uses: A=accumulator, HL=ptr/result, BC=count, DE=dest-ptr/temp (prefer over stack)
(in-package :eightbol)

(defvar *output-stream* nil)

(defun sm83-symbol (name)
  "Convert EIGHTBOL identifier to SM83 assembly symbol (PascalCase). COBOL stabby-case supported."
  (pascal-case (format nil "~a" name)))

(defmacro def-sm83-statement (statement-type &body body)
  `(defmethod compile-statement ((cpu (eql :sm83)) (statement-type (eql ,statement-type)) ast-node-data)
     (let ((statement (cons statement-type ast-node-data)))
       (declare (ignorable statement))
       ,@body)))

(defmethod compile-statement :around ((cpu (eql :sm83)) statement-type ast-node-data)
  (emit-statement-source-comment *output-stream* (cons statement-type ast-node-data))
  (call-next-method))

(defmethod compile-to-assembly (ast (cpu (eql :sm83)) output-stream)
  (unless (and (listp ast) (eq (first ast) :program))
    (error "EIGHTBOL/SM83: expected :program AST node, got ~s" (first ast)))
  (let* ((class-id (getf (rest ast) :class-id))
         (methods  (getf (rest ast) :methods)))
    (multiple-value-bind (slot-table type-table const-table service-bank-table usage-table sign-table
                          pic-size-table pic-width-table pic-frac-bits-table
                          pic-nybble-semantics-table)
        (load-copybook-tables class-id)
      (declare (ignore service-bank-table usage-table sign-table))
      (let ((*output-stream* output-stream)
            (*class-id* class-id)
            (*slot-table* slot-table)
            (*type-table* type-table)
            (*const-table* const-table)
            (*pic-size-table* pic-size-table)
            (*pic-width-table* pic-width-table)
            (*pic-frac-bits-table* pic-frac-bits-table)
            (*pic-nybble-semantics-table* pic-nybble-semantics-table))
        (format output-stream
                "; ~a -- generated by EIGHTBOL for SM83 (Game Boy)~%; DO NOT EDIT -- regenerate from ~a.cob~2%"
                class-id class-id)
        (format output-stream  "~&SECTION \"~a\", ROM0~2%" class-id)
        (dolist (method (ensure-list methods))
          (when (and (listp method) (eq (first method) :method))
            (compile-sm83-method method)))))))

(defun compile-sm83-method (method)
  (let ((*method-id* (getf (rest method) :method-id)))
    (declare (special *method-id*))
    (let* ((method-id *method-id*)
           (dispatch-label (format nil "Method~a~a"
                                   (sm83-symbol *class-id*)
                                   (sm83-symbol (format nil "~a" method-id))))
           (custom-entry (nth-value 0 (split-method-leading-assembly-entry
                                        (getf (rest method) :statements))))
           (statements (nth-value 1 (split-method-leading-assembly-entry
                                      (getf (rest method) :statements)))))
      (if custom-entry
          (progn
            (format *output-stream* "~&~%~a::" (sm83-symbol custom-entry))
            (format *output-stream* "~&~a::" dispatch-label))
          (format *output-stream* "~&~%~a::" dispatch-label))
      (dolist (statement (ensure-list statements))
        (compile-statement :sm83 (first statement) (rest statement)))
      (format *output-stream* "~&~8tret"))))

(defun compile-sm83-goto (statement)
  "Emit SM83 GOTO: unconditional @code{jp}, or compare chain when @code{:depending-on} is set."
  (let ((target (getf (rest statement) :target))
        (targets (getf (rest statement) :targets))
        (depending (getf (rest statement) :depending-on)))
    (if depending
        (let ((target-list (or targets (when target (list target)))))
          (when target-list
            (compile-sm83-load depending 1)
            (format *output-stream* "~&~8tld      b, a")
            (let ((n (length target-list)))
              (loop for i from 1 below n
                    do (format *output-stream* "~&~8tld      a, b")
                       (format *output-stream* "~&~8tcp      ~d" i)
                       (format *output-stream* "~&~8tjp      z, ~a"
                               (sm83-symbol (format nil "~a" (nth (1- i) target-list)))))
              (format *output-stream* "~&~8tjp      ~a"
                      (sm83-symbol (format nil "~a" (nth (1- n) target-list)))))))
        (format *output-stream* "~&~8tjp      ~a"
                (sm83-symbol (format nil "~a" (or target (first targets))))))))

(def-sm83-statement :goback
  (format *output-stream* "~&~8tret"))

(def-sm83-statement :exit-method
  (format *output-stream* "~&~8tret"))

(def-sm83-statement :exit-program
  (format *output-stream* "~&~8tret"))

(def-sm83-statement :stop-run
  (format *output-stream* "~&~8tret"))

(def-sm83-statement :exit
  (format *output-stream* "~&~8tret"))

(def-sm83-statement :move
  (compile-sm83-move statement))

(def-sm83-statement :invoke
  (compile-sm83-invoke statement))

(def-sm83-statement :call
  (compile-sm83-call statement))

(def-sm83-statement :if
  (compile-sm83-if statement))

(def-sm83-statement :add
  (compile-sm83-add statement))

(def-sm83-statement :subtract
  (compile-sm83-subtract statement))

(def-sm83-statement :compute
  (compile-sm83-compute statement))

(def-sm83-statement :set
  (compile-sm83-set statement))

(def-sm83-statement :log-fault
  (format *output-stream* "~&~8t; LOG FAULT ~s" (getf ast-node-data :code)))

(def-sm83-statement :debug-break
  (format *output-stream* "~&~8t; DEBUG BREAK ~s" (getf ast-node-data :code)))

(def-sm83-statement :perform
  (compile-sm83-perform statement))

(def-sm83-statement :string-blt
  (compile-sm83-string-blt statement))

(def-sm83-statement :goto
  (compile-sm83-goto statement))

(def-sm83-statement :paragraph
  (let ((name (first ast-node-data)))
    (when name
      (format *output-stream* "~&~a:" (sm83-symbol (format nil "~a" name))))))

(def-sm83-statement :evaluate
  (compile-sm83-evaluate statement))

(def-sm83-statement :inspect
  (compile-sm83-inspect statement))

(def-sm83-statement :comment
  (format *output-stream* "~&~8t; ~a"
          (let ((text (first ast-node-data)))
            (if (listp text)
                (format nil "~{~a~%~8t; ~}" (mapcar (lambda (s) (if (stringp s) s (princ-to-string s))) text))
                (princ-to-string text)))))

(def-sm83-statement :copy
  (error "EIGHTBOL: COPY ~s should have been expanded at lex time"
         (getf ast-node-data :name)))

(def-sm83-statement :divide
  (let* ((divisor (getf ast-node-data :divisor))
         (into (getf ast-node-data :into))
         (by (getf ast-node-data :by))
         (source (or by into))
         (dest (or (getf ast-node-data :giving) into))
         (signed (operand-signed-p (or source dest))))
    (if (and (expression-constant-p divisor)
             (power-of-two-p (expression-constant-value divisor)))
        (let ((shift (log2 (expression-constant-value divisor))))
          (when (or (operand-bcd-p source) (operand-bcd-p dest))
            (error 'source-error
                   :message "DIVIDE: cannot use with USAGE DECIMAL operands"
                   :detail (list :divisor divisor :source source :dest dest)))
          (unless (zerop shift)
            (compile-sm83-load (or source dest) 1)
            (dotimes (_ shift)
              (if signed
                  (format *output-stream* "~&~8tsra     a")
                  (format *output-stream* "~&~8tsrl     a")))
            (when (stringp (or source dest))
              (format *output-stream* "~&~8tld      (~a), a" (sm83-symbol (or source dest))))))
        (error 'source-error
               :message "DIVIDE: divisor must be constant power-of-two (1, 2, 4, 8, ...)"
               :detail (format nil "DIVIDE by ~s" divisor)))))

(def-sm83-statement :multiply
  (let* ((multiplier (getf ast-node-data :multiplier))
         (by (getf ast-node-data :by))
         (giving (getf ast-node-data :giving))
         (source (or giving by))
         (dest (or giving by)))
    (if (and (expression-constant-p multiplier)
             (power-of-two-p (expression-constant-value multiplier)))
        (let ((shift (log2 (expression-constant-value multiplier)))
              (target (or source dest)))
          (declare (ignore target))
          (when (or (operand-bcd-p source) (operand-bcd-p dest))
            (error 'source-error
                   :message "MULTIPLY: cannot use with USAGE DECIMAL operands"
                   :detail (list :multiplier multiplier :source source :dest dest)))
          (unless (zerop shift)
            (compile-sm83-load (or source dest) 1)
            (dotimes (_ shift)
              (format *output-stream* "~&~8tsla      a"))
            (when (stringp (or source dest))
              (format *output-stream* "~&~8tld      (~a), a" (sm83-symbol (or source dest))))))
        (error 'source-error
               :message "MULTIPLY: multiplier must be constant power-of-two (1, 2, 4, 8, ...)"
               :detail (format nil "MULTIPLY by ~s" multiplier)))))

(def-sm83-statement :invoke-super
  (unless (gethash *class-id* *parent-classes*)
    (load-classes))
  (if-let (parent-class (gethash *class-id* *parent-classes*))
    (format *output-stream* "~&~8tcall    Method~a~a"
            (sm83-symbol parent-class)
            (sm83-symbol (format nil "~a" *method-id*)))
    (error "Can't figure out parent class of ~a" *class-id*)))

(def-sm83-statement :shift-left
  (let* ((target (getf ast-node-data :target))
         (count (getf ast-node-data :count 1)))
    (compile-sm83-load target)
    (dotimes (_ count)
      (format *output-stream* "~&~8tsla      a"))
    (when (stringp target)
      (format *output-stream* "~&~8tld      (~a), a" (sm83-symbol target)))))

(def-sm83-statement :shift-right
  (let* ((target (getf ast-node-data :target))
         (count (getf ast-node-data :count 1))
         (signed (operand-signed-p target)))
    (compile-sm83-load target)
    (dotimes (_ count)
      (if signed
          (format *output-stream* "~&~8tsra      a")
          (format *output-stream* "~&~8tsrl      a")))
    (when (stringp target)
      (format *output-stream* "~&~8tld      (~a), a" (sm83-symbol target)))))

(defun sm83-expr-is-constant-p (expression)
  "True when EXPRESSION is a compile-time constant."
  (or (numberp expression)
      (and (stringp expression) (constant-p expression))))

(defun sm83-value (expression)
  "Return assembly text for EXPRESSION."
  (cond
    ((numberp expression) (format nil "~d" expression))
    ((and (stringp expression) (constant-p expression))
     (format nil "~d" (constant-value expression)))
    ((stringp expression) (bare-data-assembly-symbol expression *class-id*))
    ((eq expression :self) "Self")
    ((and (listp expression) (eq (first expression) :of))
     (sm83-symbol (format nil "~a-~a" (third expression) (second expression))))
    (t (format nil "~a" expression))))

(defun compile-sm83-load (expression &optional (width (operand-width expression)))
  "Load EXPRESSION into A (width=1) or HL (width=2)."
  (cond
    ((numberp expression)
     (if (= (or width 1) 2)
         (format *output-stream* "~&~8tld      hl, ~d" expression)
         (format *output-stream* "~&~8tld      a, ~d" expression)))
    ((and (stringp expression) (constant-p expression))
     (if (= (or width 1) 2)
         (format *output-stream* "~&~8tld      hl, ~d" (constant-value expression))
         (format *output-stream* "~&~8tld      a, ~d" (constant-value expression))))
    ((stringp expression)
     (if (= (or width 1) 2)
         (format *output-stream* "~&~8tld      hl, [~a]" (bare-data-assembly-symbol expression *class-id*))
         (format *output-stream* "~&~8tld      a, [~a]" (bare-data-assembly-symbol expression *class-id*))))
    ((and (listp expression) (eq (first expression) :of))
     (let ((slot (second expression)) (obj (third expression)))
       (when (member obj '(:self "Self" self) :test #'equal)
         (format *output-stream* "~&~8tld      hl, [Self]")
         (format *output-stream* "~&~8tld      de, ~a" (slot-symbol slot *class-id*))
         (format *output-stream* "~&~8tadd     hl, de")
         (if (= (or width 1) 2)
             (progn
               (format *output-stream* "~&~8tld      a, [hl+]")
               (format *output-stream* "~&~8tld      l, [hl]")
               (format *output-stream* "~&~8tld      h, a"))
             (format *output-stream* "~&~8tld      a, [hl]")))))
    ((and (listp expression) (eq (first expression) :subscript))
     (compile-sm83-load (third expression) 1)
     (format *output-stream* "~&~8tld      c, a")
     (format *output-stream* "~&~8tld      b, 0")
     (format *output-stream* "~&~8tld      hl, ~a" (bare-data-assembly-symbol (second expression) *class-id*))
     (format *output-stream* "~&~8tadd     hl, bc")
     (when (= (or width 1) 2)
       (format *output-stream* "~&~8tadd     hl, bc"))
     (if (= (or width 1) 2)
         (progn
           (format *output-stream* "~&~8tld      a, [hl+]")
           (format *output-stream* "~&~8tld      l, [hl]")
           (format *output-stream* "~&~8tld      h, a"))
         (format *output-stream* "~&~8tld      a, [hl]")))
    ((and (listp expression) (eq (first expression) :shift-left))
     (let ((n (if (numberp (third expression)) (third expression) 1)))
       (compile-sm83-load (second expression))
       (dotimes (_ n) (format *output-stream* "~&~8tadd     a, a"))))
    ((and (listp expression) (eq (first expression) :shift-right))
     (let ((n (if (numberp (third expression)) (third expression) 1)))
       (compile-sm83-load (second expression))
       (dotimes (_ n) (format *output-stream* "~&~8tsrl     a"))))
    ((and (listp expression) (eq (first expression) :bit-and))
     (compile-sm83-load (second expression))
     (let ((rhs (third expression)))
       (if (sm83-expr-is-constant-p rhs)
           (format *output-stream* "~&~8tand     ~a" (sm83-value rhs))
           (progn (format *output-stream* "~&~8tld      b, a")
                  (compile-sm83-load rhs)
                  (format *output-stream* "~&~8tand     b")))))
    ((and (listp expression) (eq (first expression) :bit-or))
     (compile-sm83-load (second expression))
     (let ((rhs (third expression)))
       (if (sm83-expr-is-constant-p rhs)
           (format *output-stream* "~&~8tor      ~a" (sm83-value rhs))
           (progn (format *output-stream* "~&~8tld      b, a")
                  (compile-sm83-load rhs)
                  (format *output-stream* "~&~8tor      b")))))
    ((and (listp expression) (eq (first expression) :bit-xor))
     (compile-sm83-load (second expression))
     (let ((rhs (third expression)))
       (if (sm83-expr-is-constant-p rhs)
           (format *output-stream* "~&~8txor     ~a" (sm83-value rhs))
           (progn (format *output-stream* "~&~8tld      b, a")
                  (compile-sm83-load rhs)
                  (format *output-stream* "~&~8txor     b")))))
    ((and (listp expression) (eq (first expression) :bit-not))
     (compile-sm83-load (second expression))
     (format *output-stream* "~&~8tcpl"))
    (t (format *output-stream* "~&~8t; Unsupported load ~s" expression))))

(defun compile-sm83-move (statement)
  (let* ((from (getf (rest statement) :from))
         (to (getf (rest statement) :to))
         (to-width (operand-width to))
         (from-width (expression-operand-width from)))
    (backend-unsupported-operand-width :sm83 :move (max from-width to-width) 2)
    (compile-sm83-load from)
    (cond
      ((stringp to)
       (if (= (or to-width 1) 2)
           (format *output-stream* "~&~8tld      [~a], hl" (bare-data-assembly-symbol to *class-id*))
           (format *output-stream* "~&~8tld      [~a], a" (bare-data-assembly-symbol to *class-id*))))
      ((and (listp to) (eq (first to) :of))
       (let ((slot (second to)) (obj (third to)))
         (when (member obj '(:self "Self" self) :test #'equal)
           (if (= (or to-width 1) 2)
               (progn
                 (format *output-stream* "~&~8tld      d, h")
                 (format *output-stream* "~&~8tld      e, l")
                 (format *output-stream* "~&~8tld      hl, [Self]")
                 (format *output-stream* "~&~8tld      bc, ~a" (slot-symbol slot *class-id*))
                 (format *output-stream* "~&~8tadd     hl, bc")
                 (format *output-stream* "~&~8tld      [hl], e")
                 (format *output-stream* "~&~8tinc     hl")
                 (format *output-stream* "~&~8tld      [hl], d"))
               (progn
                 (format *output-stream* "~&~8tld      hl, [Self]")
                 (format *output-stream* "~&~8tld      de, ~a" (slot-symbol slot *class-id*))
                 (format *output-stream* "~&~8tadd     hl, de")
                 (format *output-stream* "~&~8tld      [hl], a"))))))
      ((and (listp to) (eq (first to) :subscript))
       (if (= (or to-width 1) 2)
           (progn
             (format *output-stream* "~&~8tpush    hl")
             (compile-sm83-load (third to) 1)
             (format *output-stream* "~&~8tld      c, a")
             (format *output-stream* "~&~8tld      b, 0")
             (format *output-stream* "~&~8tld      hl, ~a" (bare-data-assembly-symbol (second to) *class-id*))
             (format *output-stream* "~&~8tadd     hl, bc")
             (format *output-stream* "~&~8tadd     hl, bc")
             (format *output-stream* "~&~8tpop     de")
             (format *output-stream* "~&~8tld      [hl], e")
             (format *output-stream* "~&~8tinc     hl")
             (format *output-stream* "~&~8tld      [hl], d"))
           (progn
             (format *output-stream* "~&~8tpush    af")
             (compile-sm83-load (third to) 1)
             (format *output-stream* "~&~8tld      c, a")
             (format *output-stream* "~&~8tld      b, 0")
             (format *output-stream* "~&~8tld      hl, ~a" (bare-data-assembly-symbol (second to) *class-id*))
             (format *output-stream* "~&~8tadd     hl, bc")
             (format *output-stream* "~&~8tpop     af")
             (format *output-stream* "~&~8tld      [hl], a"))))
      (t (format *output-stream* "~&~8t; Unsupported store to ~s" to)))))

(defun compile-sm83-invoke (statement)
  (let ((object (getf (rest statement) :object))
        (method (getf (rest statement) :method))
        (returning (getf (rest statement) :returning)))
    (let ((method-sym (sm83-symbol (format nil "~a" method))))
      (cond
        ((member object '(:self "Self" self) :test #'equal)
         (format *output-stream* "~&~8tcall    Invoke~a~a" (sm83-symbol *class-id*) method-sym))
        (t
         (let* ((obj-name (sm83-symbol (format nil "~a" object)))
                (obj-class (or (var-class obj-name) "Unknown")))
           (format *output-stream* "~&~8tcall    Call~a~a" obj-class method-sym))))
      (when returning
        (let ((return-width (operand-width returning)))
          (if (= (or return-width 1) 2)
              (format *output-stream* "~&~8tld      [~a], hl" (bare-data-assembly-symbol returning *class-id*))
              (format *output-stream* "~&~8tld      [~a], a" (bare-data-assembly-symbol returning *class-id*))))))))

(defun compile-sm83-call (statement)
  (let ((target (getf (rest statement) :target))
        (service (getf (rest statement) :service))
        (library (getf (rest statement) :library)))
    (declare (ignore library))
    (format *output-stream* "~&~8tcall    ~a" (sm83-symbol (format nil "~a" (or service target))))))

(defvar *sm83-label* 0)

(defun sm83-label (prefix)
  (format nil ".~a~d" prefix (incf *sm83-label*)))

(defun compile-sm83-if (statement)
  (let ((condition (getf (rest statement) :condition))
        (then-statements (getf (rest statement) :then))
        (else-statements (getf (rest statement) :else))
        (label-else (sm83-label "else"))
        (label-end (sm83-label "end")))
    (compile-sm83-condition condition label-else)
    (dolist (s (ensure-list then-statements))
      (compile-statement :sm83 (first s) (rest s)))
    (when (and else-statements (not (null else-statements)))
      (format *output-stream* "~&~8tjr      ~a" label-end))
    (format *output-stream* "~&~a:" label-else)
    (when (and else-statements (not (null else-statements)))
      (dolist (s (ensure-list else-statements))
        (compile-statement :sm83 (first s) (rest s)))
      (format *output-stream* "~&~a:" label-end))))

(defun compile-sm83-condition (condition branch-label)
  (cond
    ((and (listp condition) (member (first condition) '(= equal < less > greater) :test #'eq))
     (let* ((lhs (second condition))
            (rhs (third condition))
            (op (first condition))
            (width (max (or (operand-width lhs) 1)
                        (or (operand-width rhs) 1))))
       (if (= width 2)
           (progn
             (compile-sm83-load lhs 2)
             (format *output-stream* "~&~8tld      d, h")
             (format *output-stream* "~&~8tld      e, l")
             (compile-sm83-load rhs 2)
             (format *output-stream* "~&~8tld      a, l")
             (format *output-stream* "~&~8tsub     e")
             (format *output-stream* "~&~8tld      l, a")
             (format *output-stream* "~&~8tld      a, h")
             (format *output-stream* "~&~8tsbc     d")
             (format *output-stream* "~&~8tld      h, a")
             (ecase op
               ((= equal)
                (format *output-stream* "~&~8tld      a, h")
                (format *output-stream* "~&~8tor      l")
                (format *output-stream* "~&~8tjr      nz, ~a" branch-label))
               ((< less)  (format *output-stream* "~&~8tjr      nc, ~a" branch-label))
               ((> greater)
                (format *output-stream* "~&~8tjr      c, ~a" branch-label)
                (format *output-stream* "~&~8tjr      z, ~a" branch-label))))
           (progn
             (compile-sm83-load lhs)
             (format *output-stream* "~&~8tld      b, a")
             (compile-sm83-load rhs)
             (format *output-stream* "~&~8tcp      b")
             (ecase op
               ((= equal) (format *output-stream* "~&~8tjr      nz, ~a" branch-label))
               ((< less)  (format *output-stream* "~&~8tjr      nc, ~a" branch-label))
               ((> greater) (format *output-stream* "~&~8tjr      c, ~a" branch-label)))))))
    ((and (listp condition) (eq (first condition) :is-zero))
     (let* ((ex (second condition))
            (width (operand-width ex)))
       (compile-sm83-load ex)
       (if (= (or width 1) 2)
           (progn
             (format *output-stream* "~&~8tld      a, h")
             (format *output-stream* "~&~8tor      l"))
           (format *output-stream* "~&~8tor      a"))
       (format *output-stream* "~&~8tjr      nz, ~a" branch-label)))
    ((and (listp condition) (eq (first condition) :is-not-zero))
     (let* ((ex (second condition))
            (width (operand-width ex)))
       (compile-sm83-load ex)
       (if (= (or width 1) 2)
           (progn
             (format *output-stream* "~&~8tld      a, h")
             (format *output-stream* "~&~8tor      l"))
           (format *output-stream* "~&~8tor      a"))
       (format *output-stream* "~&~8tjr      z, ~a" branch-label)))
    ((and (listp condition) (eq (first condition) :and))
     (compile-sm83-condition (second condition) branch-label)
     (compile-sm83-condition (third condition) branch-label))
    ((and (listp condition) (eq (first condition) :or))
     (let ((label-cond2 (sm83-label "or"))
           (label-skip (sm83-label "skip")))
       (compile-sm83-condition (second condition) branch-label)
       (format *output-stream* "~&~8tjr      ~a" label-skip)
       (format *output-stream* "~&~a:" label-cond2)
       (compile-sm83-condition (third condition) branch-label)
       (format *output-stream* "~&~a:" label-skip)))
    (t (error "EIGHTBOL: condition ~s not implemented" condition))))

(defun compile-sm83-evaluate (statement)
  (let ((subject (getf (rest statement) :subject))
        (clauses (getf (rest statement) :when-clauses))
        (label-end (sm83-label "eval")))
    (dolist (clause (ensure-list clauses))
      (cond
        ((eq (first clause) :when-other)
         (dolist (s (ensure-list (second clause)))
           (compile-statement :sm83 (first s) (rest s))))
        ((eq (first clause) :when)
         (let ((phrases (second clause))
               (statements (third clause))
               (label-next (sm83-label "when")))
           (cond
             ((eq phrases 'eightbol::any)
              (dolist (s (ensure-list statements))
                (compile-statement :sm83 (first s) (rest s)))
              (format *output-stream* "~&~8tjr      ~a" label-end))
             ((or (eq phrases 'eightbol::true) (equal phrases "TRUE"))
              (let ((subject-width (operand-width subject)))
                (compile-sm83-load subject)
                (if (= (or subject-width 1) 2)
                    (progn (format *output-stream* "~&~8tld      a, h")
                           (format *output-stream* "~&~8tor      l"))
                    (format *output-stream* "~&~8tor      a"))
                (format *output-stream* "~&~8tjr      z, ~a" label-next))
              (dolist (s (ensure-list statements))
                (compile-statement :sm83 (first s) (rest s)))
              (format *output-stream* "~&~8tjr      ~a" label-end)
              (format *output-stream* "~&~a:" label-next))
             ((or (eq phrases 'eightbol::false) (equal phrases "FALSE"))
              (let ((subject-width (operand-width subject)))
                (compile-sm83-load subject)
                (if (= (or subject-width 1) 2)
                    (progn (format *output-stream* "~&~8tld      a, h")
                           (format *output-stream* "~&~8tor      l"))
                    (format *output-stream* "~&~8tor      a"))
                (format *output-stream* "~&~8tjr      nz, ~a" label-next))
              (dolist (s (ensure-list statements))
                (compile-statement :sm83 (first s) (rest s)))
              (format *output-stream* "~&~8tjr      ~a" label-end)
              (format *output-stream* "~&~a:" label-next))
             ((and (listp phrases) (eq (first phrases) :not))
              (compile-sm83-load subject)
              (format *output-stream* "~&~8tld      b, a")
              (compile-sm83-load (second phrases))
              (format *output-stream* "~&~8tcp      b")
              (format *output-stream* "~&~8tjr      z, ~a" label-next)
              (dolist (s (ensure-list statements))
                (compile-statement :sm83 (first s) (rest s)))
              (format *output-stream* "~&~8tjr      ~a" label-end)
              (format *output-stream* "~&~a:" label-next))
             ((and (listp phrases) (member (first phrases) '(:through :thru)))
              (let ((lo (second phrases)) (hi (third phrases)))
                (compile-sm83-load subject)
                (format *output-stream* "~&~8tld      b, a")
                (compile-sm83-load lo)
                (format *output-stream* "~&~8tcp      b")
                (format *output-stream* "~&~8tjr      c, ~a" label-next)
                (compile-sm83-load hi)
                (format *output-stream* "~&~8tld      c, a")
                (format *output-stream* "~&~8tld      a, b")
                (format *output-stream* "~&~8tcp      c")
                (format *output-stream* "~&~8tjr      nc, ~a" label-next)
                (dolist (s (ensure-list statements))
                  (compile-statement :sm83 (first s) (rest s)))
                (format *output-stream* "~&~8tjr      ~a" label-end)
                (format *output-stream* "~&~a:" label-next)))
             (t
              (let ((phrase-expression (if (listp phrases) (second phrases) phrases)))
                (compile-sm83-load subject)
                (format *output-stream* "~&~8tld      b, a")
                (compile-sm83-load phrase-expression)
                (format *output-stream* "~&~8tcp      b")
                (format *output-stream* "~&~8tjr      nz, ~a" label-next)
                (dolist (s (ensure-list statements))
                  (compile-statement :sm83 (first s) (rest s)))
                (format *output-stream* "~&~8tjr      ~a" label-end)
                (format *output-stream* "~&~a:" label-next))))))))
    (format *output-stream* "~&~a:" label-end)))

(defun compile-sm83-inspect (statement)
  (let ((target (getf (rest statement) :target))
        (tally (getf (rest statement) :tallying))
        (conv-from (getf (rest statement) :converting))
        (conv-to (getf (rest statement) :to))
        (replace-by (getf (rest statement) :by)))
    (let ((target-symbol (sm83-symbol (format nil "~a" target))))
      (cond
        (tally
         (let ((tally-symbol (sm83-symbol (format nil "~a" tally))))
           (format *output-stream* "~&~8t; INSPECT ~a TALLYING ~a FOR CHARACTERS" target tally)
           (format *output-stream* "~&~8tld      hl, ~a" target-symbol)
           (let ((label (sm83-label "tally"))
                 (label-done (sm83-label "tallyd"))
                 (label-skip (sm83-label "tallys")))
             (format *output-stream* "~&~a:" label)
             (format *output-stream* "~&~8tld      a, [hl]")
             (format *output-stream* "~&~8tor      a")
             (format *output-stream* "~&~8tjr      z, ~a" label-done)
             (format *output-stream* "~&~8tld      a, [~a]" tally-symbol)
             (format *output-stream* "~&~8tinc     a")
             (format *output-stream* "~&~8tld      [~a], a" tally-symbol)
             (format *output-stream* "~&~a:" label-skip)
             (format *output-stream* "~&~8tinc     hl")
             (format *output-stream* "~&~8tjr      ~a" label)
             (format *output-stream* "~&~a:" label-done))))
        (conv-from
         (format *output-stream* "~&~8t; INSPECT ~a CONVERTING" target)
         (format *output-stream* "~&~8tld      hl, ~a" target-symbol)
         (let ((label (sm83-label "insp"))
               (label-next (sm83-label "inspn"))
               (label-done (sm83-label "inspd")))
           (format *output-stream* "~&~a:" label)
           (format *output-stream* "~&~8tld      a, [hl]")
           (format *output-stream* "~&~8tor      a")
           (format *output-stream* "~&~8tjr      z, ~a" label-done)
           (if (sm83-expr-is-constant-p conv-from)
               (format *output-stream* "~&~8tcp      ~a" (sm83-value conv-from))
               (progn (format *output-stream* "~&~8tld      b, a")
                      (compile-sm83-load conv-from 1)
                      (format *output-stream* "~&~8tcp      b")))
           (format *output-stream* "~&~8tjr      nz, ~a" label-next)
           (compile-sm83-load conv-to 1)
           (format *output-stream* "~&~8tld      [hl], a")
           (format *output-stream* "~&~a:" label-next)
           (format *output-stream* "~&~8tinc     hl")
           (format *output-stream* "~&~8tjr      ~a" label)
           (format *output-stream* "~&~a:" label-done)))
        (replace-by
         (let ((length (or (gethash (format nil "~a" target) *pic-size-table*) 64)))
           (format *output-stream* "~&~8t; INSPECT ~a REPLACING CHARACTERS BY ~a" target replace-by)
           (compile-sm83-load replace-by 1)
           (format *output-stream* "~&~8tld      hl, ~a" target-symbol)
           (let ((label (sm83-label "insp")))
             (format *output-stream* "~&~8tld      b, ~d" length)
             (format *output-stream* "~&~a:" label)
             (format *output-stream* "~&~8tld      [hl], a")
             (format *output-stream* "~&~8tinc     hl")
             (format *output-stream* "~&~8tdec     b")
             (format *output-stream* "~&~8tjr      nz, ~a" label))))))))

(defun compile-sm83-add (statement)
  (let* ((from (getf (rest statement) :from))
         (to (getf (rest statement) :to))
         (giving (getf (rest statement) :giving))
         (result (or giving (and (stringp to) to)))
         (width (max (operand-width (or result to))
                     (expression-operand-width from)
                     (operand-width to)))
         (bcd-p (when result (usage-bcd-p result))))
    (assert-pic-decimal-add-compiled :sm83 statement)
    (when (and bcd-p (> (or width 1) 2))
      (dotimes (i width)
        (format *output-stream* "~&~8tld      a, [~a+~d]" (bare-data-assembly-symbol from *class-id*) i)
        (format *output-stream* "~&~8tld      b, a")
        (format *output-stream* "~&~8tld      a, [~a+~d]" (bare-data-assembly-symbol to *class-id*) i)
        (if (= i 0) (format *output-stream* "~&~8tadd     b") (format *output-stream* "~&~8tadc     b"))
        (format *output-stream* "~&~8tdaa")
        (format *output-stream* "~&~8tld      [~a+~d], a" (bare-data-assembly-symbol result *class-id*) i))
      (return-from compile-sm83-add))
    (backend-unsupported-operand-width :sm83 :add width 2)
    (if (= (or width 1) 2)
        (progn
          (compile-sm83-load to 2)
          (format *output-stream* "~&~8tld      d, h")
          (format *output-stream* "~&~8tld      e, l")
          (compile-sm83-load from 2)
          (format *output-stream* "~&~8tadd     hl, de")
          (when result
            (format *output-stream* "~&~8tld      [~a], hl" (bare-data-assembly-symbol result *class-id*))))
        (progn
          (compile-sm83-load to)
          (format *output-stream* "~&~8tld      b, a")
          (compile-sm83-load from)
          (format *output-stream* "~&~8tadd     b")
          (when bcd-p (format *output-stream* "~&~8tdaa"))
          (let ((dest (or giving (and (stringp to) to))))
            (when dest
              (format *output-stream* "~&~8tld      [~a], a" (bare-data-assembly-symbol dest *class-id*))))))))

(defun compile-sm83-subtract (statement)
  (multiple-value-bind (minuend subtrahend)
      (subtract-statement-minuend-and-subtrahend statement)
    (let* ((giving (getf (rest statement) :giving))
           (dest (or giving minuend))
           (bcd-p (when dest (usage-bcd-p dest)))
           (width (max (operand-width dest)
                       (expression-operand-width subtrahend)
                       (operand-width minuend))))
      (assert-pic-decimal-subtract-compiled :sm83 statement)
      (when (and bcd-p (> (or width 1) 2))
        (dotimes (i width)
          (format *output-stream* "~&~8tld      a, [~a+~d]" (bare-data-assembly-symbol minuend *class-id*) i)
          (format *output-stream* "~&~8tld      b, a")
          (format *output-stream* "~&~8tld      a, [~a+~d]" (bare-data-assembly-symbol subtrahend *class-id*) i)
          (if (= i 0) (format *output-stream* "~&~8tsub     b") (format *output-stream* "~&~8tsbc     b"))
          (let ((sk1 (sm83-label "bss")) (sk2 (sm83-label "bss2")))
            (format *output-stream* "~&~8tjr      nc, ~a" sk1)
            (format *output-stream* "~&~8tsub     $60")
            (format *output-stream* "~&~a:" sk1)
            (format *output-stream* "~&~8tld      b, a")
            (format *output-stream* "~&~8tand     $0F")
            (format *output-stream* "~&~8tcp      10")
            (format *output-stream* "~&~8tjr      c, ~a" sk2)
            (format *output-stream* "~&~8tld      a, b")
            (format *output-stream* "~&~8tsub     $06")
            (format *output-stream* "~&~8tld      b, a")
            (format *output-stream* "~&~a:" sk2)
            (format *output-stream* "~&~8tld      a, b"))
          (format *output-stream* "~&~8tld      [~a+~d], a" (bare-data-assembly-symbol dest *class-id*) i))
        (return-from compile-sm83-subtract))
      (backend-unsupported-operand-width :sm83 :subtract width 2)
      (if (= (or width 1) 2)
          (progn
            (compile-sm83-load minuend 2)
            (format *output-stream* "~&~8tld      d, h")
            (format *output-stream* "~&~8tld      e, l")
            (compile-sm83-load subtrahend 2)
            (format *output-stream* "~&~8tld      a, l")
            (format *output-stream* "~&~8tld      l, e")
            (format *output-stream* "~&~8tld      e, a")
            (format *output-stream* "~&~8tld      a, h")
            (format *output-stream* "~&~8tld      h, d")
            (format *output-stream* "~&~8tld      d, a")
            (format *output-stream* "~&~8tld      a, l")
            (format *output-stream* "~&~8tsub     e")
            (format *output-stream* "~&~8tld      l, a")
            (format *output-stream* "~&~8tld      a, h")
            (format *output-stream* "~&~8tsbc     d")
            (format *output-stream* "~&~8tld      h, a")
            (format *output-stream* "~&~8tld      [~a], hl" (bare-data-assembly-symbol dest *class-id*)))
          (progn
            (compile-sm83-load minuend)
            (format *output-stream* "~&~8tld      b, a")
            (compile-sm83-load subtrahend)
            (format *output-stream* "~&~8tld      c, a")
            (format *output-stream* "~&~8tld      a, b")
            (format *output-stream* "~&~8tsub     c")
            (when bcd-p
              (let ((sk1 (sm83-label "bss1")) (sk2 (sm83-label "bss2")))
                (format *output-stream* "~&~8tjr      nc, ~a" sk1)
                (format *output-stream* "~&~8tsub     $60")
                (format *output-stream* "~&~a:" sk1)
                (format *output-stream* "~&~8tld      b, a")
                (format *output-stream* "~&~8tand     $0F")
                (format *output-stream* "~&~8tcp      10")
                (format *output-stream* "~&~8tjr      c, ~a" sk2)
                (format *output-stream* "~&~8tld      a, b")
                (format *output-stream* "~&~8tsub     $06")
                (format *output-stream* "~&~8tld      b, a")
                (format *output-stream* "~&~a:" sk2)
                (format *output-stream* "~&~8tld      a, b")))
            (format *output-stream* "~&~8tld      [~a], a" (bare-data-assembly-symbol dest *class-id*)))))))

(defun compile-sm83-compute (statement)
  (let* ((target (getf (rest statement) :target))
         (expression (getf (rest statement) :expression))
         (width (max (operand-width target)
                     (expression-operand-width expression))))
    (backend-unsupported-operand-width :sm83 :compute width 2)
    (compile-sm83-load expression)
    (if (= (or width 1) 2)
        (format *output-stream* "~&~8tld      [~a], hl" (bare-data-assembly-symbol target *class-id*))
        (format *output-stream* "~&~8tld      [~a], a" (bare-data-assembly-symbol target *class-id*)))))

(defun compile-sm83-set (statement)
  (let* ((target (getf (rest statement) :target))
         (value (getf (rest statement) :value))
         (up-by (getf (rest statement) :up-by))
         (down-by (getf (rest statement) :down-by))
         (by-expression (getf (rest statement) :by))
         (address-of (getf (rest statement) :address-of))
         (to-self (getf (rest statement) :to-self))
         (width (operand-width (or target to-self up-by down-by))))
    (cond
      (up-by
       (compile-sm83-add (list :add :from by-expression :to up-by :giving nil)))
      (down-by
       (compile-sm83-subtract (list :subtract :from by-expression :from-target down-by :giving nil)))
      ((and address-of target)
       (let ((source address-of) (dest target))
         (cond
           ((and (listp source) (eq :of (first source))
                 (member (third source) '(:self "Self" self) :test #'equal))
            (format *output-stream* "~&~8tld      hl, [Self]")
            (format *output-stream* "~&~8tld      de, ~a" (slot-symbol (second source) *class-id*))
            (format *output-stream* "~&~8tadd     hl, de"))
           ((stringp source)
            (format *output-stream* "~&~8tld      hl, ~a" (sm83-symbol source)))
           (t (format *output-stream* "~&~8t; Unsupported SET ADDRESS OF source ~s" source)))
         (cond
           ((stringp dest)
            (if (= (or width 1) 2)
                (format *output-stream* "~&~8tld      [~a], hl" (sm83-symbol dest))
                (progn
                  (format *output-stream* "~&~8tld      a, l")
                  (format *output-stream* "~&~8tld      [~a], a" (sm83-symbol dest)))))
           (t (format *output-stream* "~&~8t; Unsupported SET ADDRESS OF target ~s" dest)))))
      (to-self
       (format *output-stream* "~&~8tld      hl, [Self]")
       (cond
         ((stringp to-self)
          (if (= (or width 1) 2)
              (format *output-stream* "~&~8tld      [~a], hl" (sm83-symbol to-self))
              (progn
                (format *output-stream* "~&~8tld      a, l")
                (format *output-stream* "~&~8tld      [~a], a" (sm83-symbol to-self)))))
         (t (format *output-stream* "~&~8t; Unsupported SET TO SELF destination ~s" to-self))))
      (t
       (compile-sm83-load value)
       (cond
         ((stringp target)
          (if (= (or width 1) 2)
              (format *output-stream* "~&~8tld      [~a], hl" (sm83-symbol target))
              (format *output-stream* "~&~8tld      [~a], a" (sm83-symbol target))))
         ((and (listp target) (eq (first target) :of))
          (let ((slot (second target)) (obj (third target)))
            (when (member obj '(:self "Self" self) :test #'equal)
              (if (= (or width 1) 2)
                  (progn
                    (format *output-stream* "~&~8tpush    hl")
                    (format *output-stream* "~&~8tld      hl, [Self]")
                    (format *output-stream* "~&~8tld      de, ~a" (slot-symbol slot *class-id*))
                    (format *output-stream* "~&~8tadd     hl, de")
                    (format *output-stream* "~&~8tpop     de")
                    (format *output-stream* "~&~8tld      [hl], e")
                    (format *output-stream* "~&~8tinc     hl")
                    (format *output-stream* "~&~8tld      [hl], d"))
                  (progn
                    (format *output-stream* "~&~8tld      hl, [Self]")
                    (format *output-stream* "~&~8tld      de, ~a" (slot-symbol slot *class-id*))
                    (format *output-stream* "~&~8tadd     hl, de")
                    (format *output-stream* "~&~8tld      [hl], a"))))))
         ((and (listp target) (eq (first target) :subscript))
          (if (= (or width 1) 2)
              (progn
                (format *output-stream* "~&~8tld      d, h")
                (format *output-stream* "~&~8tld      e, l")
                (compile-sm83-load (third target) 1)
                (format *output-stream* "~&~8tld      c, a")
                (format *output-stream* "~&~8tld      b, 0")
                (format *output-stream* "~&~8tld      hl, ~a" (sm83-symbol (format nil "~a" (second target))))
                (format *output-stream* "~&~8tadd     hl, bc")
                (format *output-stream* "~&~8tadd     hl, bc")
                (format *output-stream* "~&~8tld      [hl], e")
                (format *output-stream* "~&~8tinc     hl")
                (format *output-stream* "~&~8tld      [hl], d"))
              (progn
                (format *output-stream* "~&~8tld      b, a")
                (compile-sm83-load (third target) 1)
                (format *output-stream* "~&~8tld      c, a")
                (format *output-stream* "~&~8tld      a, b")
                (format *output-stream* "~&~8tld      b, 0")
                (format *output-stream* "~&~8tld      hl, ~a" (sm83-symbol (format nil "~a" (second target))))
                (format *output-stream* "~&~8tadd     hl, bc")
                (format *output-stream* "~&~8tld      [hl], a"))))
         (t (format *output-stream* "~&~8t; Unsupported set ~s" target)))))))

(defun compile-sm83-perform (statement)
  (let ((procedure (getf (rest statement) :procedure))
        (times (getf (rest statement) :times))
        (until (getf (rest statement) :until)))
    (cond
      (times
       (let ((label (sm83-label "perf"))
             (label-done (sm83-label "perfd"))
             (times-width (operand-width times)))
         (compile-sm83-load times)
         (if (= (or times-width 1) 2)
             (progn
               (format *output-stream* "~&~8tld      b, h")
               (format *output-stream* "~&~8tld      c, l")
               (format *output-stream* "~&~a:" label)
               (format *output-stream* "~&~8tld      a, b")
               (format *output-stream* "~&~8tor      c")
               (format *output-stream* "~&~8tjr      z, ~a" label-done)
               (format *output-stream* "~&~8tpush    bc")
               (format *output-stream* "~&~8tcall    ~a" (sm83-symbol (format nil "~a" procedure)))
               (format *output-stream* "~&~8tpop     bc")
               (format *output-stream* "~&~8tdec     bc")
               (format *output-stream* "~&~8tjr      ~a" label)
               (format *output-stream* "~&~a:" label-done))
             (progn
               (format *output-stream* "~&~8tld      b, a")
               (format *output-stream* "~&~a:" label)
               (format *output-stream* "~&~8tpush    bc")
               (format *output-stream* "~&~8tcall    ~a" (sm83-symbol (format nil "~a" procedure)))
               (format *output-stream* "~&~8tpop     bc")
               (format *output-stream* "~&~8tdec     b")
               (format *output-stream* "~&~8tjr      nz, ~a" label)))))
      (until
       (let ((label-loop (sm83-label "loop"))
             (label-end (sm83-label "end")))
         (format *output-stream* "~&~a:" label-loop)
         (compile-sm83-condition until label-end)
         (format *output-stream* "~&~8tcall    ~a" (sm83-symbol (format nil "~a" procedure)))
         (format *output-stream* "~&~8tjr      ~a" label-loop)
         (format *output-stream* "~&~a:" label-end)))
      (t
       (format *output-stream* "~&~8tcall    ~a" (sm83-symbol (format nil "~a" procedure)))))))

(defun sm83-string-operand-address (operand)
  (cond
    ((and (listp operand) (eq (first operand) :refmod))
     (let* ((base (getf (rest operand) :base))
            (start (getf (rest operand) :start))
            (base-string (sm83-symbol (format nil "~a" base))))
       (if (and (integerp start) (= start 1))
           base-string
           (format nil "~a+~d" base-string (1- start)))))
    (t (sm83-symbol (format nil "~a" operand)))))

(defun compile-sm83-string-blt (statement)
  (let ((source (getf (rest statement) :source))
        (dest (getf (rest statement) :dest))
        (length (getf (rest statement) :length)))
    (let ((len (or (%string-blt-refmod-length source)
                   (%string-blt-refmod-length dest)
                   length 64))
          (source-address (sm83-string-operand-address source))
          (dest-address (sm83-string-operand-address dest)))
      (format *output-stream* "~&~8tld      hl, ~a" source-address)
      (format *output-stream* "~&~8tld      de, ~a" dest-address)
      (let ((label (sm83-label "blt")))
        (format *output-stream* "~&~8tld      bc, ~d" len)
        (format *output-stream* "~&~a:" label)
        (format *output-stream* "~&~8tld      a, [hl+]")
        (format *output-stream* "~&~8tld      [de], a")
        (format *output-stream* "~&~8tinc     de")
        (format *output-stream* "~&~8tdec     bc")
        (format *output-stream* "~&~8tld      a, b")
        (format *output-stream* "~&~8tor      c")
        (format *output-stream* "~&~8tjr      nz, ~a" label)))))
