;; src/backend-m68k.lisp — Motorola 68000 code generation backend
;;
;; Targets the Motorola 68000 instruction set ONLY (not 68010, 68020, etc.).
;; The 68000 has:
;;   Data registers:    D0–D7
;;   Address registers: A0–A7 (A7 = stack pointer)
;;   Instructions: move, add, sub, cmp, and, or, eor, not, neg, clr
;;   Control: jsr, jmp, rts, bra, bcc/bcs/beq/bne/bmi/bpl/bvc/bvs
;;   Sizes: .b (byte), .w (word), .l (long)
;;
;; Output: GAS/AT&T-style 68000 assembly (move.b, move.w, etc.)
;; Uses: D0=accumulator, A0=address temp, D1=temp
(in-package :eightbol)

(defun m68k-symbol (name)
  "Convert EIGHTBOL identifier to m68k assembly symbol (PascalCase). COBOL stabby-case supported."
  (cobol-id-to-assembly-symbol (format nil "~a" name)))

(defmethod compile-to-assembly (ast (cpu (eql :m68k)) output-stream)
  (unless (and (listp ast) (eq (first ast) :program))
    (error "EIGHTBOL/m68k: expected :program AST node, got ~s" (first ast)))
  (let* ((class-id (getf (rest ast) :class-id))
         (methods  (getf (rest ast) :methods)))
    (multiple-value-bind (slot-table type-table const-table service-bank-table usage-table sign-table pic-size-table pic-width-table)
        (load-copybook-tables class-id)
      (let ((*usage-table* usage-table)
            (*sign-table* sign-table))
        (declare (ignore service-bank-table sign-table))
        (format output-stream
                "| ~a -- generated by EIGHTBOL for m68k (68000)~%| DO NOT EDIT -- regenerate from ~a.cob~2%"
                class-id class-id)
        (format output-stream "~&~10t.text")
        (dolist (method (ensure-list methods))
          (when (and (listp method) (eq (first method) :method))
            (compile-m68k-method output-stream method class-id
                                slot-table type-table const-table pic-size-table pic-width-table)))))))

(defun compile-m68k-method (out method class-id slot-table type-table const-table pic-size-table pic-width-table)
  (let ((method-id  (getf (rest method) :method-id))
        (statements (getf (rest method) :statements)))
    (format out "~&~%Method~a~a:"
            (m68k-symbol class-id) (m68k-symbol (format nil "~a" method-id)))
    (dolist (stmt (ensure-list statements))
      (compile-m68k-statement out stmt class-id slot-table type-table const-table pic-size-table pic-width-table))
    (format out "~&~10trts")))

(defun compile-m68k-goto (out stmt class-id slot-table type-table const-table pic-size-table pic-width-table)
  "Emit m68k GOTO: unconditional @code{jmp}, or @code{cmp}/@code{beq} chain when @code{:depending-on} is set."
  (declare (ignore pic-size-table))
  (let ((target (getf (rest stmt) :target))
        (targets (getf (rest stmt) :targets))
        (dep (getf (rest stmt) :depending-on)))
    (if dep
        (let ((tgt-list (or targets (when target (list target)))))
          (when tgt-list
            (compile-m68k-load out dep class-id slot-table const-table pic-width-table 1)
            (let ((n (length tgt-list)))
              (loop for i from 1 below n
                    do (format out "~&~10tcmp.b   #~d, %d0" i)
                       (format out "~&~10tbeq     ~a"
                               (m68k-symbol (format nil "~a" (nth (1- i) tgt-list)))))
              (format out "~&~10tjmp     ~a"
                      (m68k-symbol (format nil "~a" (nth (1- n) tgt-list)))))))
        (format out "~&~10tjmp     ~a"
                (m68k-symbol (format nil "~a" (or target (first targets))))))))

(defun compile-m68k-statement (out stmt class-id slot-table type-table const-table pic-size-table pic-width-table)
  (unless (and (listp stmt) (first stmt)) (return-from compile-m68k-statement))
  (ecase (first stmt)
    (:goback (format out "~&~10trts"))
    (:exit-method (format out "~&~10trts"))
    (:exit-program (format out "~&~10trts"))
    (:stop-run (format out "~&~10trts"))
    (:exit (format out "~&~10trts"))
    (:move (compile-m68k-move out stmt class-id slot-table const-table pic-width-table))
    (:invoke (compile-m68k-invoke out stmt class-id type-table))
    (:call (compile-m68k-call out stmt))
    (:if (compile-m68k-if out stmt class-id slot-table type-table const-table pic-size-table pic-width-table))
    (:add (compile-m68k-add out stmt class-id slot-table const-table pic-width-table))
    (:subtract (compile-m68k-subtract out stmt class-id slot-table const-table pic-width-table))
    (:compute (compile-m68k-compute out stmt class-id slot-table const-table pic-width-table))
    (:set (compile-m68k-set out stmt class-id slot-table const-table pic-width-table))
    (:log-fault (format out "~&~10t| LOG FAULT ~s" (getf (rest stmt) :code)))
    (:debug-break (format out "~&~10t| DEBUG BREAK ~s" (getf (rest stmt) :code)))
    (:perform (compile-m68k-perform out stmt class-id slot-table type-table const-table pic-width-table))
    (:string-blt (compile-m68k-string-blt out stmt class-id slot-table const-table))
    (:goto
     (compile-m68k-goto out stmt class-id slot-table type-table const-table pic-size-table pic-width-table))
    (:paragraph
     (let ((name (or (getf (rest stmt) :paragraph) (second stmt))))
       (when name (format out "~&~a:" (m68k-symbol (format nil "~a" name))))))
    (:evaluate
     (compile-m68k-evaluate out stmt class-id slot-table type-table const-table pic-size-table pic-width-table))
    (:inspect
     (compile-m68k-inspect out stmt class-id slot-table const-table pic-size-table pic-width-table))
    (:copy (error "EIGHTBOL: COPY ~s should have been expanded at lex time"
                  (getf (rest stmt) :name)))))

(defun m68k-size-suffix (width)
  "Return .b or .w for width 1 or 2."
  (ecase (or width 1)
    (1 ".b")
    (2 ".w")))

(defun compile-m68k-load (out expr class-id slot-table const-table pic-width-table
                          &optional (width (operand-width expr pic-width-table)))
  "Load EXPR into D0. Uses .b for byte, .w for word."
  (let ((sz (m68k-size-suffix width)))
    (cond
      ((numberp expr)
       (format out "~&~10tmove~a  #~d, %d0" sz expr))
      ((and (stringp expr) (constant-p expr const-table))
       (format out "~&~10tmove~a  #~d, %d0" sz (constant-value expr const-table)))
      ((stringp expr)
       (format out "~&~10tmove~a  ~a, %d0" sz (m68k-symbol expr)))
      ((and (listp expr) (eq (first expr) :of))
       (let ((slot (second expr)) (obj (third expr)))
         (when (member obj '(:self "Self" self) :test #'equal)
           (format out "~&~10tmove.l  Self, %a0")
           (format out "~&~10tmove~a  ~a(%a0), %d0"
                   sz (slot-symbol slot slot-table class-id)))))
      ((and (listp expr) (eq (first expr) :subscript))
       (compile-m68k-load out (third expr) class-id slot-table const-table pic-width-table 1)
       (when (= (or width 1) 2)
         (format out "~&~10tadd.w   %d0, %d0"))
       (format out "~&~10tmove.l  #~a, %a0" (m68k-symbol (format nil "~a" (second expr))))
       (format out "~&~10tmove~a  (%a0,%d0.w), %d0" sz))
      ((and (listp expr) (eq (first expr) :shift-left))
       (let ((n (if (numberp (third expr)) (third expr) 1)))
         (compile-m68k-load out (second expr) class-id slot-table const-table pic-width-table)
         (dotimes (_ n) (format out "~&~10tlsl~a   #1, %d0" sz))))
      ((and (listp expr) (eq (first expr) :shift-right))
       (let ((n (if (numberp (third expr)) (third expr) 1)))
         (compile-m68k-load out (second expr) class-id slot-table const-table pic-width-table)
         (dotimes (_ n) (format out "~&~10tlsr~a   #1, %d0" sz))))
      ((and (listp expr) (eq (first expr) :bit-and))
       (compile-m68k-load out (second expr) class-id slot-table const-table pic-width-table)
       (let ((rhs (third expr)))
         (if (m68k-expr-is-constant-p rhs const-table)
             (format out "~&~10tandi~a  #~a, %d0" sz (m68k-value rhs const-table))
             (progn (format out "~&~10tmove~a  %d0, %d1" sz)
                    (compile-m68k-load out rhs class-id slot-table const-table pic-width-table)
                    (format out "~&~10tand~a   %d1, %d0" sz)))))
      ((and (listp expr) (eq (first expr) :bit-or))
       (compile-m68k-load out (second expr) class-id slot-table const-table pic-width-table)
       (let ((rhs (third expr)))
         (if (m68k-expr-is-constant-p rhs const-table)
             (format out "~&~10tori~a   #~a, %d0" sz (m68k-value rhs const-table))
             (progn (format out "~&~10tmove~a  %d0, %d1" sz)
                    (compile-m68k-load out rhs class-id slot-table const-table pic-width-table)
                    (format out "~&~10tor~a    %d1, %d0" sz)))))
      ((and (listp expr) (eq (first expr) :bit-xor))
       (compile-m68k-load out (second expr) class-id slot-table const-table pic-width-table)
       (let ((rhs (third expr)))
         (if (m68k-expr-is-constant-p rhs const-table)
             (format out "~&~10teori~a  #~a, %d0" sz (m68k-value rhs const-table))
             (progn (format out "~&~10tmove~a  %d0, %d1" sz)
                    (compile-m68k-load out rhs class-id slot-table const-table pic-width-table)
                    (format out "~&~10teor~a   %d1, %d0" sz)))))
      ((and (listp expr) (eq (first expr) :bit-not))
       (compile-m68k-load out (second expr) class-id slot-table const-table pic-width-table)
       (format out "~&~10tnot~a   %d0" sz))
      (t (format out "~&~10t| Unsupported load ~s" expr)))))

(defun compile-m68k-move (out stmt class-id slot-table const-table pic-width-table)
  (let ((from (getf (rest stmt) :from))
        (to   (getf (rest stmt) :to))
        (to-w (operand-width to pic-width-table)))
    (compile-m68k-load out from class-id slot-table const-table pic-width-table)
    (let ((sz (m68k-size-suffix to-w)))
      (cond
        ((stringp to)
         (format out "~&~10tmove~a  %d0, ~a" sz (m68k-symbol to)))
        ((and (listp to) (eq (first to) :of))
         (let ((slot (second to)) (obj (third to)))
           (when (member obj '(:self "Self" self) :test #'equal)
             (format out "~&~10tmove.l  Self, %a0")
             (format out "~&~10tmove~a  %d0, ~a(%a0)"
                     sz (slot-symbol slot slot-table class-id)))))
        ((and (listp to) (eq (first to) :subscript))
         (format out "~&~10tmove~a  %d0, %d1" sz)
         (compile-m68k-load out (third to) class-id slot-table const-table pic-width-table 1)
         (when (= (or to-w 1) 2)
           (format out "~&~10tadd.w   %d0, %d0"))
         (format out "~&~10tmove.l  #~a, %a0" (m68k-symbol (format nil "~a" (second to))))
         (format out "~&~10tmove~a  %d1, (%a0,%d0.w)" sz))
        (t (format out "~&~10t| Unsupported store to ~s" to))))))

(defun compile-m68k-invoke (out stmt class-id type-table)
  (let ((object (getf (rest stmt) :object))
        (method (getf (rest stmt) :method))
        (returning (getf (rest stmt) :returning)))
    (let ((method-sym (m68k-symbol (format nil "~a" method))))
      (cond
        ((member object '(:self "Self" self) :test #'equal)
         (format out "~&~10tjsr     Invoke~a~a" (m68k-symbol class-id) method-sym))
        (t
         (let* ((obj-name (m68k-symbol (format nil "~a" object)))
                (obj-class (or (var-class obj-name type-table) "Unknown")))
           (format out "~&~10tjsr     Call~a~a" obj-class method-sym))))
      (when returning
        (format out "~&~10tmove.b  %d0, ~a" (m68k-symbol (format nil "~a" returning)))))))

(defun compile-m68k-call (out stmt)
  (let ((target (getf (rest stmt) :target))
        (service (getf (rest stmt) :service))
        (library (getf (rest stmt) :library)))
    (format out "~&~10tjsr     ~a" (m68k-symbol (format nil "~a" (or service target))))))

(defvar *m68k-label* 0)

(defun m68k-label (prefix)
  (format nil ".L~a~d" prefix (incf *m68k-label*)))

(defun compile-m68k-if (out stmt class-id slot-table type-table const-table pic-size-table pic-width-table)
  (let ((condition (getf (rest stmt) :condition))
        (then-stmts (getf (rest stmt) :then))
        (else-stmts (getf (rest stmt) :else))
        (lbl-else (m68k-label "else"))
        (lbl-end (m68k-label "end")))
    (compile-m68k-condition out condition class-id slot-table type-table const-table pic-width-table lbl-else)
    (dolist (s (ensure-list then-stmts))
      (compile-m68k-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table))
    (when (and else-stmts (not (null else-stmts)))
      (format out "~&~10tbra     ~a" lbl-end))
    (format out "~&~a:" lbl-else)
    (when (and else-stmts (not (null else-stmts)))
      (dolist (s (ensure-list else-stmts))
        (compile-m68k-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table))
      (format out "~&~a:" lbl-end))))

(defun compile-m68k-condition (out condition class-id slot-table type-table const-table pic-width-table branch-label)
  (cond
    ((and (listp condition) (member (first condition) '(= equal < less > greater) :test #'eq))
     (let ((lhs (second condition)) (rhs (third condition)) (op (first condition))
           (sz (m68k-size-suffix (max (or (operand-width lhs pic-width-table) 1)
                                      (or (operand-width rhs pic-width-table) 1)))))
       (compile-m68k-load out lhs class-id slot-table const-table pic-width-table)
       (format out "~&~10tmove~a  %d0, %d1" sz)
       (compile-m68k-load out rhs class-id slot-table const-table pic-width-table)
       (format out "~&~10tcmp~a   %d1, %d0" sz)
       (ecase op
         ((= equal) (format out "~&~10tbne     ~a" branch-label))
         ((< less)  (format out "~&~10tbge     ~a" branch-label))
         ((> greater) (format out "~&~10tble     ~a" branch-label)))))
    ((and (listp condition) (eq (first condition) :is-zero))
     (let ((ex (second condition))
           (sz (m68k-size-suffix (operand-width ex pic-width-table))))
       (compile-m68k-load out ex class-id slot-table const-table pic-width-table)
       (format out "~&~10ttst~a   %d0" sz)
       (format out "~&~10tbne     ~a" branch-label)))
    ((and (listp condition) (eq (first condition) :is-not-zero))
     (let ((ex (second condition))
           (sz (m68k-size-suffix (operand-width ex pic-width-table))))
       (compile-m68k-load out ex class-id slot-table const-table pic-width-table)
       (format out "~&~10ttst~a   %d0" sz)
       (format out "~&~10tbeq     ~a" branch-label)))
    ((and (listp condition) (eq (first condition) :and))
     (compile-m68k-condition out (second condition) class-id slot-table type-table const-table pic-width-table branch-label)
     (compile-m68k-condition out (third condition) class-id slot-table type-table const-table pic-width-table branch-label))
    ((and (listp condition) (eq (first condition) :or))
     (let ((lbl-cond2 (m68k-label "or"))
           (lbl-skip (m68k-label "skip")))
       (compile-m68k-condition out (second condition) class-id slot-table type-table const-table pic-width-table lbl-cond2)
       (format out "~&~10tbra     ~a" lbl-skip)
       (format out "~&~a:" lbl-cond2)
       (compile-m68k-condition out (third condition) class-id slot-table type-table const-table pic-width-table branch-label)
       (format out "~&~a:" lbl-skip)))
    (t (error "EIGHTBOL: condition ~s not implemented" condition))))

(defun m68k-value (expr &optional const-table)
  (cond
    ((numberp expr) (format nil "~d" expr))
    ((and (stringp expr) (constant-p expr const-table))
     (format nil "~d" (constant-value expr const-table)))
    ((stringp expr) (m68k-symbol expr))
    ((eq expr :self) "Self")
    ((and (listp expr) (eq (first expr) :of))
     (m68k-symbol (format nil "~a-~a" (third expr) (second expr))))
    (t (format nil "~a" expr))))

(defun m68k-expr-is-constant-p (expr const-table)
  (or (numberp expr)
      (and (stringp expr) (constant-p expr const-table))))

(defun compile-m68k-evaluate (out stmt class-id slot-table type-table const-table pic-size-table pic-width-table)
  (let ((subject (getf (rest stmt) :subject))
        (clauses (getf (rest stmt) :when-clauses))
        (lbl-end (m68k-label "eval")))
    (dolist (clause (ensure-list clauses))
      (cond
        ((eq (first clause) :when-other)
         (dolist (s (ensure-list (second clause)))
           (compile-m68k-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table)))
        ((eq (first clause) :when)
         (let ((phrases (second clause))
               (stmts (third clause))
               (lbl-next (m68k-label "when")))
           (cond
             ((eq phrases 'eightbol::any)
              (dolist (s (ensure-list stmts))
                (compile-m68k-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table))
              (format out "~&~10tbra     ~a" lbl-end))
             ((or (eq phrases 'eightbol::true) (equal phrases "TRUE"))
              (compile-m68k-load out subject class-id slot-table const-table pic-width-table)
              (format out "~&~10ttst.b   %d0")
              (format out "~&~10tbeq     ~a" lbl-next)
              (dolist (s (ensure-list stmts))
                (compile-m68k-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table))
              (format out "~&~10tbra     ~a" lbl-end)
              (format out "~&~a:" lbl-next))
             ((or (eq phrases 'eightbol::false) (equal phrases "FALSE"))
              (compile-m68k-load out subject class-id slot-table const-table pic-width-table)
              (format out "~&~10ttst.b   %d0")
              (format out "~&~10tbne     ~a" lbl-next)
              (dolist (s (ensure-list stmts))
                (compile-m68k-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table))
              (format out "~&~10tbra     ~a" lbl-end)
              (format out "~&~a:" lbl-next))
             ((and (listp phrases) (eq (first phrases) :not))
              (let ((sz (m68k-size-suffix (max (or (operand-width subject pic-width-table) 1)
                                                (or (operand-width (second phrases) pic-width-table) 1)))))
                (compile-m68k-load out subject class-id slot-table const-table pic-width-table)
                (format out "~&~10tmove~a  %d0, %d1" sz)
                (compile-m68k-load out (second phrases) class-id slot-table const-table pic-width-table)
                (format out "~&~10tcmp~a   %d1, %d0" sz)
                (format out "~&~10tbeq     ~a" lbl-next)
                (dolist (s (ensure-list stmts))
                  (compile-m68k-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table))
                (format out "~&~10tbra     ~a" lbl-end)
                (format out "~&~a:" lbl-next)))
             ((and (listp phrases) (member (first phrases) '(:through :thru)))
              (let ((lo (second phrases)) (hi (third phrases))
                    (sz (m68k-size-suffix (max (or (operand-width subject pic-width-table) 1)
                                               (or (operand-width lo pic-width-table) 1)
                                               (or (operand-width hi pic-width-table) 1)))))
                (compile-m68k-load out subject class-id slot-table const-table pic-width-table)
                (format out "~&~10tmove~a  %d0, %d1" sz)
                (compile-m68k-load out lo class-id slot-table const-table pic-width-table)
                (format out "~&~10tcmp~a   %d0, %d1" sz)
                (format out "~&~10tbgt     ~a" lbl-next)
                (compile-m68k-load out hi class-id slot-table const-table pic-width-table)
                (format out "~&~10tcmp~a   %d1, %d0" sz)
                (format out "~&~10tblt     ~a" lbl-next)
                (dolist (s (ensure-list stmts))
                  (compile-m68k-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table))
                (format out "~&~10tbra     ~a" lbl-end)
                (format out "~&~a:" lbl-next)))
             (t
              (let ((phrase-expr (if (listp phrases) (second phrases) phrases))
                    (sz (m68k-size-suffix (max (or (operand-width subject pic-width-table) 1)
                                               (or (operand-width phrase-expr pic-width-table) 1)))))
                (compile-m68k-load out subject class-id slot-table const-table pic-width-table)
                (format out "~&~10tmove~a  %d0, %d1" sz)
                (compile-m68k-load out phrase-expr class-id slot-table const-table pic-width-table)
                (format out "~&~10tcmp~a   %d1, %d0" sz)
                (format out "~&~10tbne     ~a" lbl-next)
                (dolist (s (ensure-list stmts))
                  (compile-m68k-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table))
                (format out "~&~10tbra     ~a" lbl-end)
                (format out "~&~a:" lbl-next))))))))
    (format out "~&~a:" lbl-end)))

(defun compile-m68k-inspect (out stmt class-id slot-table const-table pic-size-table pic-width-table)
  (let ((target (getf (rest stmt) :target))
        (tally (getf (rest stmt) :tallying))
        (conv-from (getf (rest stmt) :converting))
        (conv-to (getf (rest stmt) :to))
        (repl-by (getf (rest stmt) :by)))
    (let ((tgt-sym (m68k-symbol (format nil "~a" target))))
      (cond
        (tally
         (let ((tally-sym (m68k-symbol (format nil "~a" tally))))
           (format out "~&~10t| INSPECT ~a TALLYING ~a FOR CHARACTERS" target tally)
           (format out "~&~10tlea     ~a, %a0" tgt-sym)
           (let ((lbl (m68k-label "tally")) (lbl-done (m68k-label "tallyd")) (lbl-skip (m68k-label "tallys")))
             (format out "~&~a:" lbl)
             (format out "~&~10tmove.b  (%a0)+, %d0")
             (format out "~&~10ttst.b   %d0")
             (format out "~&~10tbeq     ~a" lbl-done)
             (format out "~&~10tmove.b  ~a, %d0" tally-sym)
             (format out "~&~10taddq.b  #1, %d0")
             (format out "~&~10tmove.b  %d0, ~a" tally-sym)
             (format out "~&~a:" lbl-skip)
             (format out "~&~10tbra     ~a" lbl)
             (format out "~&~a:" lbl-done))))
        (conv-from
         (format out "~&~10t| INSPECT ~a CONVERTING" target)
         (format out "~&~10tlea     ~a, %a0" tgt-sym)
         (let ((lbl (m68k-label "insp")) (lbl-next (m68k-label "inspn")) (lbl-done (m68k-label "inspd")))
           (format out "~&~a:" lbl)
           (format out "~&~10tmove.b  (%a0), %d0")
           (format out "~&~10ttst.b   %d0")
           (format out "~&~10tbeq     ~a" lbl-done)
           (if (m68k-expr-is-constant-p conv-from const-table)
               (format out "~&~10tcmp.b   #~d, %d0"
                       (if (numberp conv-from) conv-from (constant-value (format nil "~a" conv-from) const-table)))
               (progn (format out "~&~10tmove.b  %d0, %d1")
                      (compile-m68k-load out conv-from class-id slot-table const-table pic-width-table 1)
                      (format out "~&~10tcmp.b   %d0, %d1")))
           (format out "~&~10tbne     ~a" lbl-next)
           (compile-m68k-load out conv-to class-id slot-table const-table pic-width-table 1)
           (format out "~&~10tmove.b  %d0, (%a0)")
           (format out "~&~a:" lbl-next)
           (format out "~&~10taddq.l  #1, %a0")
           (format out "~&~10tbra     ~a" lbl)
           (format out "~&~a:" lbl-done)))
        (repl-by
         (let ((len (or (pic-size (format nil "~a" target) pic-size-table) 64)))
           (format out "~&~10t| INSPECT ~a REPLACING CHARACTERS BY ~a" target repl-by)
           (compile-m68k-load out repl-by class-id slot-table const-table pic-width-table 1)
           (format out "~&~10tlea     ~a, %a0" tgt-sym)
           (let ((lbl (m68k-label "insp")))
             (format out "~&~10tmove.w  #~d, %d1" len)
             (format out "~&~a:" lbl)
             (format out "~&~10tmove.b  %d0, (%a0)+")
             (format out "~&~10tsubq.w  #1, %d1")
             (format out "~&~10tbne     ~a" lbl))))))))

(defun compile-m68k-add (out stmt class-id slot-table const-table pic-width-table)
  (let ((from (getf (rest stmt) :from))
        (to (getf (rest stmt) :to))
        (giving (getf (rest stmt) :giving))
        (result (or giving (and (stringp to) to)))
        (w (operand-width (or result to) pic-width-table))
        (bcd-p (when result (usage-bcd-p (expr-to-width-name result))))
        (sz (m68k-size-suffix w)))
    (compile-m68k-load out to class-id slot-table const-table pic-width-table)
    (format out "~&~10tmove~a  %d0, %d1" sz)
    (compile-m68k-load out from class-id slot-table const-table pic-width-table)
    (if (and bcd-p (= (or w 1) 1))
        (progn
          (format out "~&~10tmoveq   #0, %%d2")
          (format out "~&~10tmove    %%d2, %%ccr")
          (format out "~&~10tabcd    %%d1, %%d0"))
        (format out "~&~10tadd~a   %d1, %d0" sz))
    (when result
      (format out "~&~10tmove~a  %d0, ~a" sz (m68k-symbol (format nil "~a" result))))))

(defun compile-m68k-subtract (out stmt class-id slot-table const-table pic-width-table)
  (let ((from (getf (rest stmt) :from))
        (from-target (getf (rest stmt) :from-target))
        (giving (getf (rest stmt) :giving))
        (dest (or giving from-target))
        (w (operand-width dest pic-width-table))
        (bcd-p (when dest (usage-bcd-p (expr-to-width-name dest))))
        (sz (m68k-size-suffix w)))
    (compile-m68k-load out from-target class-id slot-table const-table pic-width-table)
    (format out "~&~10tmove~a  %d0, %d1" sz)
    (compile-m68k-load out from class-id slot-table const-table pic-width-table)
    (if (and bcd-p (= (or w 1) 1))
        (progn
          (format out "~&~10tmoveq   #0, %%d2")
          (format out "~&~10tmove    %%d2, %%ccr")
          (format out "~&~10tsbcd    %%d0, %%d1")
          (format out "~&~10tmove.b  %d1, %d0"))
        (progn
          (format out "~&~10tsub~a   %d0, %d1" sz)
          (format out "~&~10tmove~a  %d1, %d0" sz)))
    (format out "~&~10tmove~a  %d0, ~a" sz (m68k-symbol (format nil "~a" dest)))))

(defun compile-m68k-compute (out stmt class-id slot-table const-table pic-width-table)
  (let ((target (getf (rest stmt) :target))
        (expr (getf (rest stmt) :expression))
        (w (operand-width target pic-width-table))
        (sz (m68k-size-suffix w)))
    (compile-m68k-load out expr class-id slot-table const-table pic-width-table)
    (format out "~&~10tmove~a  %d0, ~a" sz (m68k-symbol (format nil "~a" target)))))

(defun compile-m68k-set (out stmt class-id slot-table const-table pic-width-table)
  (let ((target (getf (rest stmt) :target))
        (value (getf (rest stmt) :value))
        (up-by (getf (rest stmt) :up-by))
        (down-by (getf (rest stmt) :down-by))
        (by-expr (getf (rest stmt) :by))
        (address-of (getf (rest stmt) :address-of))
        (to-self (getf (rest stmt) :to-self))
        (w (operand-width (or target to-self up-by down-by) pic-width-table))
        (sz (m68k-size-suffix w)))
    (cond
      (up-by
       (compile-m68k-add out (list :add :from by-expr :to up-by :giving nil) class-id slot-table const-table pic-width-table))
      (down-by
       (compile-m68k-subtract out (list :subtract :from by-expr :from-target down-by :giving nil) class-id slot-table const-table pic-width-table))
      ((and address-of target)
       (let ((src address-of) (dest target))
         (cond
           ((slot-of-self-p src)
            (format out "~&~10tmove.l  Self, %a0")
            (format out "~&~10tlea.l   ~a(%a0), %a0"
                    (slot-symbol (second (slot-of-expr src)) class-id))
            (format out "~&~10tmove.l  %a0, %d0"))
           ((stringp src)
            (format out "~&~10tlea.l   ~a, %a0" (m68k-symbol src))
            (format out "~&~10tmove.l  %a0, %d0"))
           (t (format out "~&~10t| Unsupported SET ADDRESS OF source ~s" src)))
         (cond
           ((stringp dest)
            (format out "~&~10tmove~a  %d0, ~a" sz (m68k-symbol dest)))
           ((and (listp dest) (eq (first dest) :of))
            (let ((slot (second dest)) (obj (third dest)))
              (when (member obj '(:self "Self" self) :test #'equal)
                (format out "~&~10tmove.l  Self, %a0")
                (format out "~&~10tmove~a  %d0, ~a(%a0)"
                        sz (slot-symbol slot class-id)))))
           (t (format out "~&~10t| Unsupported SET ADDRESS OF target ~s" dest)))))
      (to-self
       (format out "~&~10tmove.l  Self, %a0")
       (format out "~&~10tmove.l  %a0, %d0")
       (cond
         ((stringp to-self)
          (format out "~&~10tmove~a  %d0, ~a" sz (m68k-symbol to-self)))
         ((and (listp to-self) (eq (first to-self) :of))
          (let ((slot (second to-self)) (obj (third to-self)))
            (when (member obj '(:self "Self" self) :test #'equal)
              (format out "~&~10tmove.l  Self, %a0")
              (format out "~&~10tmove~a  %d0, ~a(%a0)"
                      sz (slot-symbol slot class-id)))))
         (t (format out "~&~10t| Unsupported SET TO SELF destination ~s" to-self)))))
      (t
       (compile-m68k-load out value class-id slot-table const-table pic-width-table)
       (cond
         ((stringp target)
          (format out "~&~10tmove~a  %d0, ~a" sz (m68k-symbol target)))
         ((and (listp target) (eq (first target) :of))
          (let ((slot (second target)) (obj (third target)))
            (when (member obj '(:self "Self" self) :test #'equal)
              (format out "~&~10tmove.l  Self, %a0")
              (format out "~&~10tmove~a  %d0, ~a(%a0)"
                      sz (slot-symbol slot class-id)))))
         ((and (listp target) (eq (first target) :subscript))
          (format out "~&~10tmove~a  %d0, %d1" sz)
          (compile-m68k-load out (third target) class-id slot-table const-table pic-width-table 1)
          (when (= (or w 1) 2)
            (format out "~&~10tadd.w   %d0, %d0"))
          (format out "~&~10tmove.l  #~a, %a0" (m68k-symbol (format nil "~a" (second target))))
          (format out "~&~10tmove~a  %d1, (%a0,%d0.w)" sz))
         (t (format out "~&~10t| Unsupported set ~s" target))))))

(defun compile-m68k-perform (out stmt class-id slot-table type-table const-table pic-width-table)
  (let ((proc (getf (rest stmt) :procedure))
        (times (getf (rest stmt) :times))
        (until (getf (rest stmt) :until)))
    (cond
      (times
       (let ((lbl (m68k-label "perf")))
         (compile-m68k-load out times class-id slot-table const-table pic-width-table)
         (format out "~&~10tmove.b  %d0, %d1")
         (format out "~&~a:" lbl)
         (format out "~&~10tjsr     ~a" (m68k-symbol (format nil "~a" proc)))
         (format out "~&~10tsubq.b  #1, %d1")
         (format out "~&~10tbne     ~a" lbl)))
      (until
       (let ((lbl-loop (m68k-label "loop"))
             (lbl-end (m68k-label "end")))
         (format out "~&~a:" lbl-loop)
         (compile-m68k-condition out until class-id slot-table type-table const-table pic-width-table lbl-end)
         (format out "~&~10tjsr     ~a" (m68k-symbol (format nil "~a" proc)))
         (format out "~&~10tbra     ~a" lbl-loop)
         (format out "~&~a:" lbl-end)))
      (t
       (format out "~&~10tjsr     ~a" (m68k-symbol (format nil "~a" proc)))))))

(defun m68k-string-operand-address (operand)
  (cond
    ((and (listp operand) (eq (first operand) :refmod))
     (let* ((base (getf (rest operand) :base))
            (start (getf (rest operand) :start))
            (base-str (m68k-symbol (format nil "~a" base))))
       (if (and (integerp start) (= start 1))
           base-str
           (format nil "~a+~d" base-str (1- start)))))
    (t (m68k-symbol (format nil "~a" operand)))))

(defun compile-m68k-string-blt (out stmt class-id slot-table const-table)
  (let ((source (getf (rest stmt) :source))
        (dest (getf (rest stmt) :dest))
        (length (getf (rest stmt) :length)))
    (let ((len (or (and (listp source) (getf source :length))
                   (and (listp dest) (getf dest :length))
                   length 64))
          (src-addr (m68k-string-operand-address source))
          (dst-addr (m68k-string-operand-address dest)))
      (format out "~&~10tlea     ~a, %a0" src-addr)
      (format out "~&~10tlea     ~a, %a1" dst-addr)
      (let ((lbl (m68k-label "blt")))
        (format out "~&~10tmove.w  #~d, %d1" len)
        (format out "~&~a:" lbl)
        (format out "~&~10tmove.b  (%a0)+, %d0")
        (format out "~&~10tmove.b  %d0, (%a1)+")
        (format out "~&~10tsubq.w  #1, %d1")
        (format out "~&~10tbne     ~a" lbl)))))
