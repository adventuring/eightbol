;; src/backend-ARM7.lisp — ARM7TDMI code generation backend (GBA)
;;
;; Targets the Nintendo Game Boy Advance ARM7TDMI (@code{armv4t}): Thumb is the
;; default code path for size (typical with devkitARM / binutils). Registers
;; R0–R15 (R13=SP, R14=LR, R15=PC). Emits unified GAS syntax (@code{.thumb},
;; @code{.syntax unified}) plus @code{.cpu arm7tdmi} for correct instruction set.
;;
;; Instructions used: movs, ldr/ldrb/ldrh, str/strb/strh, add, subs, cmp,
;; b/bl/bne/..., bx lr. Uses: r0=value, r1/r2/r3 scratch and addresses.
(in-package :eightbol)

(defun arm7-symbol (name)
  "Convert EIGHTBOL identifier to ARM assembly symbol (PascalCase). COBOL stabby-case supported."
  (cobol-id-to-assembly-symbol (format nil "~a" name)))

(defmethod compile-to-assembly (ast (cpu (eql :arm7)) output-stream)
  "Compile AST to ARM7TDMI assembly for OUTPUT-STREAM (GBA-oriented Thumb GAS).

CPU must be @code{:arm7}. AST is a @code{:program} plist. Output is suitable for
assembly with a Game Boy Advance toolchain (e.g. devkitARM @command{as}) when
linked with labels @code{Self}, slot globals, and invoke stubs your runtime provides."
  (unless (and (listp ast) (eq (first ast) :program))
    (error "EIGHTBOL/ARM7: expected :program AST node, got ~s" (first ast)))
  (let* ((class-id (getf (rest ast) :class-id))
         (methods  (getf (rest ast) :methods)))
    (multiple-value-bind (slot-table type-table const-table service-bank-table usage-table sign-table pic-size-table pic-width-table)
        (load-copybook-tables class-id)
      (declare (ignore service-bank-table usage-table sign-table))
      (format output-stream
              "@ ~a -- generated by EIGHTBOL for ARM7 (Game Boy Advance)~%@ DO NOT EDIT -- regenerate from ~a.cob~2%"
              class-id class-id)
      (format output-stream  "~&~8t.arch armv4t")
      (format output-stream  "~&~8t.cpu arm7tdmi")
      (format output-stream  "~&~8t.thumb")
      (format output-stream  "~&~8t.syntax unified~2%")
      (dolist (method (ensure-list methods))
        (when (and (listp method) (eq (first method) :method))
          (compile-arm7-method output-stream method class-id
                               slot-table type-table const-table
                               pic-size-table pic-width-table))))))

(defun compile-arm7-method (out method class-id slot-table type-table const-table pic-size-table pic-width-table)
  "Emit one @code{:method} body: @code{.thumb_func} label, statements, fallback @code{bx lr}."
  (let ((*slot-table* slot-table)
        (*type-table* type-table)
        (*const-table* const-table)
        (*pic-size-table* pic-size-table)
        (*pic-width-table* pic-width-table)
        (*class-id* class-id))
    (declare (special *slot-table* *type-table* *const-table* *pic-size-table*
                      *pic-width-table* *class-id*))
    (let* ((method-id  (getf (rest method) :method-id))
           (statements (ensure-list (getf (rest method) :statements)))
           (last-stmt (car (last statements))))
      (format out  "~&~8t.thumb_func")
      (format out  "~&Method~a~a:"
              (arm7-symbol class-id) (arm7-symbol (format nil "~a" method-id)))
      (dolist (stmt statements)
        (compile-arm7-statement out stmt class-id slot-table type-table const-table pic-size-table pic-width-table))
      (unless (and last-stmt (listp last-stmt)
                   (member (first last-stmt)
                           '(:goback :exit-method :exit-program :exit :stop-run)))
        (format out  "~&~8tbx      lr")))))

(defun compile-arm7-goto (out stmt class-id slot-table type-table const-table pic-size-table pic-width-table)
  "Emit ARM7 GOTO: unconditional @code{b}, or @code{cmp}/@code{beq} chain when @code{:depending-on} is set."
  (declare (ignore pic-size-table))
  (let ((target (getf (rest stmt) :target))
        (targets (getf (rest stmt) :targets))
        (dep (getf (rest stmt) :depending-on)))
    (if dep
        (let ((tgt-list (or targets (when target (list target)))))
          (when tgt-list
            (compile-arm7-load out dep class-id slot-table const-table pic-width-table 1)
            (let ((n (length tgt-list)))
              (loop for i from 1 below n
                    do (format out "~&~8tcmp     r0, #~d" i)
                       (format out "~&~8tbeq     ~a"
                               (arm7-symbol (format nil "~a" (nth (1- i) tgt-list)))))
              (format out "~&~8tb       ~a"
                      (arm7-symbol (format nil "~a" (nth (1- n) tgt-list)))))))
        (format out "~&~8tb       ~a"
                (arm7-symbol (format nil "~a" (or target (first targets))))))))

(defun compile-arm7-statement (out stmt class-id slot-table type-table const-table pic-size-table pic-width-table)
  (unless (and (listp stmt) (first stmt)) (return-from compile-arm7-statement))
  (ecase (first stmt)
    (:goback (format out  "~&~8tbx      lr"))
    (:exit-method (format out  "~&~8tbx      lr"))
    (:exit-program (format out  "~&~8tbx      lr"))
    (:stop-run (format out  "~&~8tbx      lr"))
    (:exit (format out  "~&~8tbx      lr"))
    (:move (compile-arm7-move out stmt class-id slot-table const-table pic-width-table))
    (:invoke (compile-arm7-invoke out stmt class-id type-table pic-width-table))
    (:call (compile-arm7-call out stmt))
    (:if (compile-arm7-if out stmt class-id slot-table type-table const-table pic-size-table pic-width-table))
    (:add (compile-arm7-add out stmt class-id slot-table const-table pic-width-table))
    (:subtract (compile-arm7-subtract out stmt class-id slot-table const-table pic-width-table))
    (:compute (compile-arm7-compute out stmt class-id slot-table const-table pic-width-table))
    (:set (compile-arm7-set out stmt class-id slot-table const-table pic-width-table))
    (:log-fault (format out  "~&~8t@ LOG FAULT ~s" (getf (rest stmt) :code)))
    (:debug-break (format out  "~&~8t@ DEBUG BREAK ~s" (getf (rest stmt) :code)))
    (:perform (compile-arm7-perform out stmt class-id slot-table type-table const-table pic-width-table))
    (:string-blt (compile-arm7-string-blt out stmt class-id slot-table const-table))
    (:goto
     (compile-arm7-goto out stmt class-id slot-table type-table const-table pic-size-table pic-width-table))
    (:paragraph
     (let ((name (or (getf (rest stmt) :paragraph) (second stmt))))
       (when name (format out  "~&~a:" (arm7-symbol (format nil "~a" name))))))
    (:evaluate
     (compile-arm7-evaluate out stmt class-id slot-table type-table const-table pic-size-table pic-width-table))
    (:inspect
     (compile-arm7-inspect out stmt class-id slot-table const-table pic-size-table pic-width-table))
    (:copy (error "EIGHTBOL: COPY ~s should have been expanded at lex time"
                  (getf (rest stmt) :name)))))

(defun arm7-load-op (width)
  "Return ldrb or ldrh for width 1 or 2."
  (if (= (or width 1) 2) "ldrh" "ldrb"))

(defun arm7-store-op (width)
  "Return strb or strh for width 1 or 2."
  (if (= (or width 1) 2) "strh" "strb"))

(defun compile-arm7-load (out expr class-id slot-table const-table pic-width-table &optional (width (operand-width expr pic-width-table)))
  (let ((op (arm7-load-op width)))
    (cond
      ((numberp expr)
       (format out  "~&~8tmovs    r0, #~d" expr))
      ((and (stringp expr) (constant-p expr))
       (format out  "~&~8tmovs    r0, #~d" (constant-value expr)))
      ((stringp expr)
       (format out  "~&~8tldr     r2, =~a" (arm7-symbol expr))
       (format out  "~&~8t~a     r0, [r2]" op))
      ((and (listp expr) (eq (first expr) :of))
       (let ((slot (second expr)) (obj (third expr)))
         (when (member obj '(:self "Self" self) :test #'equal)
           (format out  "~&~8tldr     r2, =Self")
           (format out  "~&~8tldr     r2, [r2]")
           (format out  "~&~8t~a     r0, [r2, #~a]" op (slot-symbol slot class-id)))))
      ((and (listp expr) (eq (first expr) :subscript))
       (compile-arm7-load out (third expr) class-id slot-table const-table pic-width-table 1)
       (when (= (or width 1) 2)
         (format out  "~&~8tlsls    r0, r0, #1"))
       (format out  "~&~8tldr     r2, =~a" (arm7-symbol (format nil "~a" (second expr))))
       (format out  "~&~8t~a     r0, [r2, r0]" op))
      ((and (listp expr) (eq (first expr) :shift-left))
       (let ((n (if (numberp (third expr)) (third expr) 1)))
         (compile-arm7-load out (second expr) class-id slot-table const-table pic-width-table)
         (dotimes (_ n) (format out  "~&~8tlsls    r0, r0, #1"))))
      ((and (listp expr) (eq (first expr) :shift-right))
       (let ((n (if (numberp (third expr)) (third expr) 1)))
         (compile-arm7-load out (second expr) class-id slot-table const-table pic-width-table)
         (dotimes (_ n) (format out  "~&~8tlsrs    r0, r0, #1"))))
      ((and (listp expr) (eq (first expr) :bit-and))
       (compile-arm7-load out (second expr) class-id slot-table const-table pic-width-table)
       (let ((rhs (third expr)))
         (if (arm7-expr-is-constant-p rhs const-table)
             (format out  "~&~8tands    r0, r0, #~d" (if (numberp rhs) rhs (constant-value rhs)))
             (progn (format out  "~&~8tmovs    r1, r0")
                    (compile-arm7-load out rhs class-id slot-table const-table pic-width-table)
                    (format out  "~&~8tands    r0, r0, r1")))))
      ((and (listp expr) (eq (first expr) :bit-or))
       (compile-arm7-load out (second expr) class-id slot-table const-table pic-width-table)
       (let ((rhs (third expr)))
         (if (arm7-expr-is-constant-p rhs const-table)
             (format out  "~&~8torrs    r0, r0, #~d" (if (numberp rhs) rhs (constant-value rhs)))
             (progn (format out  "~&~8tmovs    r1, r0")
                    (compile-arm7-load out rhs class-id slot-table const-table pic-width-table)
                    (format out  "~&~8torrs    r0, r0, r1")))))
      ((and (listp expr) (eq (first expr) :bit-xor))
       (compile-arm7-load out (second expr) class-id slot-table const-table pic-width-table)
       (let ((rhs (third expr)))
         (if (arm7-expr-is-constant-p rhs const-table)
             (format out  "~&~8teors    r0, r0, #~d" (if (numberp rhs) rhs (constant-value rhs)))
             (progn (format out  "~&~8tmovs    r1, r0")
                    (compile-arm7-load out rhs class-id slot-table const-table pic-width-table)
                    (format out  "~&~8teors    r0, r0, r1")))))
      ((and (listp expr) (eq (first expr) :bit-not))
       (compile-arm7-load out (second expr) class-id slot-table const-table pic-width-table)
       (format out  "~&~8tmvns    r0, r0"))
      (t (format out  "~&~8t@ Unsupported load ~s" expr)))))

(defun compile-arm7-move (out stmt class-id slot-table const-table pic-width-table)
  (let ((from (getf (rest stmt) :from))
        (to-dest (getf (rest stmt) :to))
        (to-w (operand-width to-dest pic-width-table))
        (op   (arm7-store-op to-w)))
    (compile-arm7-load out from class-id slot-table const-table pic-width-table)
    (cond
      ((stringp to-dest)
       (format out  "~&~8tldr     r2, =~a" (arm7-symbol to-dest))
       (format out  "~&~8t~a     r0, [r2]" op))
      ((and (listp to-dest) (eq (first to-dest) :of))
       (let ((slot (second to-dest)) (obj (third to-dest)))
         (when (member obj '(:self "Self" self) :test #'equal)
           (format out  "~&~8tldr     r2, =Self")
           (format out  "~&~8tldr     r2, [r2]")
           (format out  "~&~8t~a     r0, [r2, #~a]"
                   op (slot-symbol slot class-id)))))
      ((and (listp to-dest) (eq (first to-dest) :subscript))
       (format out  "~&~8tmovs    r1, r0")
       (compile-arm7-load out (third to-dest) class-id slot-table const-table pic-width-table 1)
       (when (= (or to-w 1) 2)
         (format out  "~&~8tlsls    r0, r0, #1"))
       (format out  "~&~8tldr     r2, =~a" (arm7-symbol (format nil "~a" (second to-dest))))
       (format out  "~&~8t~a     r1, [r2, r0]" op))
      (t (format out  "~&~8t@ Unsupported store to ~s" to-dest)))))

(defun compile-arm7-invoke (out stmt class-id type-table pic-width-table)
  (let* ((object (getf (rest stmt) :object))
         (method (getf (rest stmt) :method))
         (returning (getf (rest stmt) :returning))
         (op (arm7-store-op (if returning
                                (operand-width returning pic-width-table)
                                1))))
    (let ((method-sym (arm7-symbol (format nil "~a" method))))
      (cond
        ((member object '(:self "Self" self) :test #'equal)
         (format out  "~&~8tbl      Invoke~a~a" (arm7-symbol class-id) method-sym))
        (t
         (let* ((obj-name (arm7-symbol (format nil "~a" object)))
                (obj-class (or (var-class obj-name) "Unknown")))
           (format out  "~&~8tbl      Call~a~a" obj-class method-sym))))
      (when returning
        (format out  "~&~8tldr     r2, =~a" (arm7-symbol (format nil "~a" returning)))
        (format out  "~&~8t~a     r0, [r2]" op)))))

(defun compile-arm7-call (out stmt)
  (let ((target (getf (rest stmt) :target))
        (service (getf (rest stmt) :service))
        (library (getf (rest stmt) :library)))
    (format out  "~&~8tbl      ~a" (arm7-symbol (format nil "~a" (or service target))))))

(defvar *arm7-label* 0)

(defun arm7-label (prefix)
  (format nil ".L~a~d" prefix (incf *arm7-label*)))

(defun compile-arm7-if (out stmt class-id slot-table type-table const-table pic-size-table pic-width-table)
  (let ((condition (getf (rest stmt) :condition))
        (then-stmts (getf (rest stmt) :then))
        (else-stmts (getf (rest stmt) :else))
        (lbl-else (arm7-label "else"))
        (lbl-end (arm7-label "end")))
    (compile-arm7-condition out condition class-id slot-table type-table const-table pic-width-table lbl-else)
    (dolist (s (ensure-list then-stmts))
      (compile-arm7-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table))
    (when (and else-stmts (not (null else-stmts)))
      (format out  "~&~8tb       ~a" lbl-end))
    (format out  "~&~a:" lbl-else)
    (when (and else-stmts (not (null else-stmts)))
      (dolist (s (ensure-list else-stmts))
        (compile-arm7-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table))
      (format out  "~&~a:" lbl-end))))

(defun compile-arm7-condition (out condition class-id slot-table type-table const-table pic-width-table branch-label)
  (cond
    ((and (listp condition) (member (first condition) '(= equal < less > greater) :test #'eq))
     (let ((lhs (second condition)) (rhs (third condition)) (op (first condition)))
       (compile-arm7-load out lhs class-id slot-table const-table pic-width-table)
       (format out  "~&~8tmovs    r1, r0")
       (compile-arm7-load out rhs class-id slot-table const-table pic-width-table)
       (format out  "~&~8tcmp     r0, r1")
       (ecase op
         ((= equal) (format out  "~&~8tbne     ~a" branch-label))
         ((< less)  (format out  "~&~8tbge     ~a" branch-label))
         ((> greater) (format out  "~&~8tble     ~a" branch-label)))))
    ((and (listp condition) (eq (first condition) :is-zero))
     (compile-arm7-load out (second condition) class-id slot-table const-table pic-width-table)
     (format out  "~&~8tcmp     r0, #0")
     (format out  "~&~8tbne     ~a" branch-label))
    ((and (listp condition) (eq (first condition) :is-not-zero))
     (compile-arm7-load out (second condition) class-id slot-table const-table pic-width-table)
     (format out  "~&~8tcmp     r0, #0")
     (format out  "~&~8tbeq     ~a" branch-label))
    ((and (listp condition) (eq (first condition) :and))
     (compile-arm7-condition out (second condition) class-id slot-table type-table const-table pic-width-table branch-label)
     (compile-arm7-condition out (third condition) class-id slot-table type-table const-table pic-width-table branch-label))
    ((and (listp condition) (eq (first condition) :or))
     (let ((lbl-cond2 (arm7-label "or"))
           (lbl-skip (arm7-label "skip")))
       (compile-arm7-condition out (second condition) class-id slot-table type-table const-table pic-width-table lbl-cond2)
       (format out  "~&~8tb       ~a" lbl-skip)
       (format out  "~&~a:" lbl-cond2)
       (compile-arm7-condition out (third condition) class-id slot-table type-table const-table pic-width-table branch-label)
       (format out  "~&~a:" lbl-skip)))
    (t (error "EIGHTBOL: condition ~s not implemented" condition))))

(defun arm7-expr-is-constant-p (expr const-table)
  "True if EXPR is a compile-time constant. CONST-TABLE is unused (see @code{*const-table*})."
  (declare (ignore const-table))
  (or (numberp expr)
      (and (stringp expr) (constant-p expr))))

(defun compile-arm7-evaluate (out stmt class-id slot-table type-table const-table pic-size-table pic-width-table)
  (let ((subject (getf (rest stmt) :subject))
        (clauses (getf (rest stmt) :when-clauses))
        (lbl-end (arm7-label "eval")))
    (dolist (clause (ensure-list clauses))
      (cond
        ((eq (first clause) :when-other)
         (dolist (s (ensure-list (second clause)))
           (compile-arm7-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table)))
        ((eq (first clause) :when)
         (let ((phrases (second clause))
               (stmts (third clause))
               (lbl-next (arm7-label "when")))
           (cond
             ((eq phrases 'eightbol::any)
              (dolist (s (ensure-list stmts))
                (compile-arm7-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table))
              (format out  "~&~8tb       ~a" lbl-end))
             ((or (eq phrases 'eightbol::true) (equal phrases "TRUE"))
              (compile-arm7-load out subject class-id slot-table const-table pic-width-table)
              (format out  "~&~8tcmp     r0, #0")
              (format out  "~&~8tbeq     ~a" lbl-next)
              (dolist (s (ensure-list stmts))
                (compile-arm7-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table))
              (format out  "~&~8tb       ~a" lbl-end)
              (format out  "~&~a:" lbl-next))
             ((or (and (symbolp phrases) (string= (symbol-name phrases) "FALSE"))
                  (equal phrases "FALSE"))
              (compile-arm7-load out subject class-id slot-table const-table pic-width-table)
              (format out  "~&~8tcmp     r0, #0")
              (format out  "~&~8tbne     ~a" lbl-next)
              (dolist (s (ensure-list stmts))
                (compile-arm7-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table))
              (format out  "~&~8tb       ~a" lbl-end)
              (format out  "~&~a:" lbl-next))
             ((and (listp phrases) (eq (first phrases) :not))
              (compile-arm7-load out subject class-id slot-table const-table pic-width-table)
              (format out  "~&~8tmovs    r1, r0")
              (compile-arm7-load out (second phrases) class-id slot-table const-table pic-width-table)
              (format out  "~&~8tcmp     r0, r1")
              (format out  "~&~8tbeq     ~a" lbl-next)
              (dolist (s (ensure-list stmts))
                (compile-arm7-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table))
              (format out  "~&~8tb       ~a" lbl-end)
              (format out  "~&~a:" lbl-next))
             ((and (listp phrases) (member (first phrases) '(:through :thru)))
              (let ((lo (second phrases)) (hi (third phrases)))
                (compile-arm7-load out subject class-id slot-table const-table pic-width-table)
                (format out  "~&~8tmovs    r1, r0")
                (compile-arm7-load out lo class-id slot-table const-table pic-width-table)
                (format out  "~&~8tcmp     r0, r1")
                (format out  "~&~8tblt     ~a" lbl-next)
                (compile-arm7-load out hi class-id slot-table const-table pic-width-table)
                (format out  "~&~8tcmp     r1, r0")
                (format out  "~&~8tblt     ~a" lbl-next)
                (dolist (s (ensure-list stmts))
                  (compile-arm7-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table))
                (format out  "~&~8tb       ~a" lbl-end)
                (format out  "~&~a:" lbl-next)))
             (t
              (let ((phrase-expr (if (listp phrases) (second phrases) phrases)))
                (compile-arm7-load out subject class-id slot-table const-table pic-width-table)
                (format out  "~&~8tmovs    r1, r0")
                (compile-arm7-load out phrase-expr class-id slot-table const-table pic-width-table)
                (format out  "~&~8tcmp     r0, r1")
                (format out  "~&~8tbne     ~a" lbl-next)
                (dolist (s (ensure-list stmts))
                  (compile-arm7-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table))
                (format out  "~&~8tb       ~a" lbl-end)
                (format out  "~&~a:" lbl-next))))))))
    (format out  "~&~a:" lbl-end)))

(defun compile-arm7-inspect (out stmt class-id slot-table const-table pic-size-table pic-width-table)
  (let ((target (getf (rest stmt) :target))
        (tally (getf (rest stmt) :tallying))
        (conv-from (getf (rest stmt) :converting))
        (conv-to (getf (rest stmt) :to))
        (repl-by (getf (rest stmt) :by)))
    (let ((tgt-sym (arm7-symbol (format nil "~a" target))))
      (cond
        (tally
         (let ((tally-sym (arm7-symbol (format nil "~a" tally))))
           (format out  "~&~8t@ INSPECT ~a TALLYING ~a FOR CHARACTERS" target tally)
           (format out  "~&~8tldr     r2, =~a" tgt-sym)
           (let ((lbl (arm7-label "tally")) (lbl-done (arm7-label "tallyd")) (lbl-skip (arm7-label "tallys")))
             (format out  "~&~a:" lbl)
             (format out  "~&~8tldrb    r0, [r2]")
             (format out  "~&~8tcmp     r0, #0")
             (format out  "~&~8tbeq     ~a" lbl-done)
             (format out  "~&~8tldr     r1, =~a" tally-sym)
             (format out  "~&~8tldrb    r0, [r1]")
             (format out  "~&~8tadds    r0, #1")
             (format out  "~&~8tstrb    r0, [r1]")
             (format out  "~&~a:" lbl-skip)
             (format out  "~&~8tadds    r2, #1")
             (format out  "~&~8tb       ~a" lbl)
             (format out  "~&~a:" lbl-done))))
        (conv-from
         (format out  "~&~8t@ INSPECT ~a CONVERTING" target)
         (format out  "~&~8tldr     r2, =~a" tgt-sym)
         (let ((lbl (arm7-label "insp")) (lbl-next (arm7-label "inspn")) (lbl-done (arm7-label "inspd")))
           (format out  "~&~a:" lbl)
           (format out  "~&~8tldrb    r0, [r2]")
           (format out  "~&~8tcmp     r0, #0")
           (format out  "~&~8tbeq     ~a" lbl-done)
           (if (arm7-expr-is-constant-p conv-from const-table)
               (format out  "~&~8tcmp     r0, #~d"
                       (if (numberp conv-from) conv-from (constant-value (format nil "~a" conv-from))))
               (progn (format out  "~&~8tmovs    r1, r0")
                      (compile-arm7-load out conv-from class-id slot-table const-table pic-width-table 1)
                      (format out  "~&~8tcmp     r0, r1")))
           (format out  "~&~8tbne     ~a" lbl-next)
           (compile-arm7-load out conv-to class-id slot-table const-table pic-width-table 1)
           (format out  "~&~8tstrb    r0, [r2]")
           (format out  "~&~a:" lbl-next)
           (format out  "~&~8tadds    r2, #1")
           (format out  "~&~8tb       ~a" lbl)
           (format out  "~&~a:" lbl-done)))
        (repl-by
         (let ((len (or (gethash (format nil "~a" target) pic-size-table) 64)))
           (format out  "~&~8t@ INSPECT ~a REPLACING CHARACTERS BY ~a" target repl-by)
           (compile-arm7-load out repl-by class-id slot-table const-table pic-width-table 1)
           (format out  "~&~8tldr     r2, =~a" tgt-sym)
           (let ((lbl (arm7-label "insp")))
             (format out  "~&~8tmovs    r3, #~d" len)
             (format out  "~&~a:" lbl)
             (format out  "~&~8tstrb    r0, [r2]")
             (format out  "~&~8tadds    r2, #1")
             (format out  "~&~8tsubs    r3, #1")
             (format out  "~&~8tbne     ~a" lbl))))))))

(defun compile-arm7-add (out stmt class-id slot-table const-table pic-width-table)
  (let ((from (getf (rest stmt) :from))
        (to-op (getf (rest stmt) :to))
        (giving (getf (rest stmt) :giving))
        (result (or giving (and (stringp to-op) to-op) (and (listp to-op) (eq (first to-op) :subscript) to-op)))
        (w (operand-width (or result to-op) pic-width-table))
        (op (arm7-store-op w)))
    (compile-arm7-load out to-op class-id slot-table const-table pic-width-table)
    (format out  "~&~8tmovs    r1, r0")
    (compile-arm7-load out from class-id slot-table const-table pic-width-table)
    (format out  "~&~8tadd     r0, r1")
    (when result
      (cond
        ((stringp result)
         (format out  "~&~8tldr     r2, =~a" (arm7-symbol result))
         (format out  "~&~8t~a     r0, [r2]" op))
        ((and (listp result) (eq (first result) :subscript))
         (format out  "~&~8tmovs    r1, r0")
         (compile-arm7-load out (third result) class-id slot-table const-table pic-width-table 1)
         (when (= (or w 1) 2)
           (format out  "~&~8tlsls    r0, r0, #1"))
         (format out  "~&~8tldr     r2, =~a" (arm7-symbol (format nil "~a" (second result))))
         (format out  "~&~8t~a     r1, [r2, r0]" op))
        (t (format out  "~&~8t@ Unsupported add result ~s" result))))))

(defun compile-arm7-subtract (out stmt class-id slot-table const-table pic-width-table)
  (let ((from (getf (rest stmt) :from))
        (from-target (getf (rest stmt) :from-target))
        (giving (getf (rest stmt) :giving))
        (dest (or giving from-target))
        (w (operand-width dest pic-width-table))
        (op (arm7-store-op w)))
    (compile-arm7-load out from-target class-id slot-table const-table pic-width-table)
    (format out  "~&~8tmovs    r1, r0")
    (compile-arm7-load out from class-id slot-table const-table pic-width-table)
    (format out  "~&~8tsubs    r0, r1, r0")
    (cond
      ((stringp dest)
       (format out  "~&~8tldr     r2, =~a" (arm7-symbol dest))
       (format out  "~&~8t~a     r0, [r2]" op))
      ((and (listp dest) (eq (first dest) :subscript))
       (format out  "~&~8tmovs    r1, r0")
       (compile-arm7-load out (third dest) class-id slot-table const-table pic-width-table 1)
       (when (= (or w 1) 2)
         (format out  "~&~8tlsls    r0, r0, #1"))
       (format out  "~&~8tldr     r2, =~a" (arm7-symbol (format nil "~a" (second dest))))
       (format out  "~&~8t~a     r1, [r2, r0]" op))
      (t (format out  "~&~8t@ Unsupported subtract dest ~s" dest)))))

(defun compile-arm7-compute (out stmt class-id slot-table const-table pic-width-table)
  (let ((target (getf (rest stmt) :target))
        (expr (getf (rest stmt) :expression))
        (w (operand-width target pic-width-table))
        (op (arm7-store-op w)))
    (compile-arm7-load out expr class-id slot-table const-table pic-width-table)
    (cond
      ((stringp target)
       (format out  "~&~8tldr     r2, =~a" (arm7-symbol target))
       (format out  "~&~8t~a     r0, [r2]" op))
      ((and (listp target) (eq (first target) :subscript))
       (format out  "~&~8tmovs    r1, r0")
       (compile-arm7-load out (third target) class-id slot-table const-table pic-width-table 1)
       (when (= (or w 1) 2)
         (format out  "~&~8tlsls    r0, r0, #1"))
       (format out  "~&~8tldr     r2, =~a" (arm7-symbol (format nil "~a" (second target))))
       (format out  "~&~8t~a     r1, [r2, r0]" op))
      (t (format out  "~&~8t@ Unsupported compute target ~s" target)))))

(defun compile-arm7-set (out stmt class-id slot-table const-table pic-width-table)
  (let ((target (getf (rest stmt) :target))
        (value (getf (rest stmt) :value))
        (up-by (getf (rest stmt) :up-by))
        (down-by (getf (rest stmt) :down-by))
        (by-expr (getf (rest stmt) :by))
        (address-of (getf (rest stmt) :address-of))
        (to-self (getf (rest stmt) :to-self))
        (w (operand-width (or target to-self up-by down-by) pic-width-table))
        (op (arm7-store-op w)))
    (cond
      (up-by
       (compile-arm7-add out (list :add :from by-expr :to up-by :giving nil) class-id slot-table const-table pic-width-table))
      (down-by
       (compile-arm7-subtract out (list :subtract :from by-expr :from-target down-by :giving nil) class-id slot-table const-table pic-width-table))
      ((and address-of target)
       (let ((src address-of) (dest target))
         (cond
           ((slot-of-self-p src)
            (format out "~&~8tldr     r2, =Self")
            (format out "~&~8tldr     r2, [r2]")
            (format out "~&~8tadds    r0, r2, #~a"
                    (slot-symbol (second (slot-of-expr src)) class-id)))
           ((stringp src)
            (format out "~&~8tldr     r0, =~a" (arm7-symbol src)))
           (t (format out "~&~8t@ Unsupported SET ADDRESS OF source ~s" src)))
         (cond
           ((stringp dest)
            (format out "~&~8tldr     r2, =~a" (arm7-symbol dest))
            (format out "~&~8t~a     r0, [r2]" op))
           ((and (listp dest) (eq (first dest) :of))
            (let ((slot (second dest)) (obj (third dest)))
              (when (member obj '(:self "Self" self) :test #'equal)
                (format out "~&~8tldr     r2, =Self")
                (format out "~&~8tldr     r2, [r2]")
                (format out "~&~8t~a     r0, [r2, #~a]"
                        op (slot-symbol slot class-id)))))
           (t (format out "~&~8t@ Unsupported SET ADDRESS OF target ~s" dest)))))
      (to-self
       (format out "~&~8tldr     r2, =Self")
       (format out "~&~8tldr     r0, [r2]")
       (cond
         ((stringp to-self)
          (format out "~&~8tldr     r2, =~a" (arm7-symbol to-self))
          (format out "~&~8t~a     r0, [r2]" op))
         ((and (listp to-self) (eq (first to-self) :of))
          (let ((slot (second to-self)) (obj (third to-self)))
            (when (member obj '(:self "Self" self) :test #'equal)
              (format out "~&~8tldr     r2, =Self")
              (format out "~&~8tldr     r2, [r2]")
              (format out "~&~8t~a     r0, [r2, #~a]"
                      op (slot-symbol slot class-id)))))
         (t (format out "~&~8t@ Unsupported SET TO SELF destination ~s" to-self)))))
      (t
       (compile-arm7-load out value class-id slot-table const-table pic-width-table)
       (cond
         ((stringp target)
          (format out "~&~8tldr     r2, =~a" (arm7-symbol target))
          (format out "~&~8t~a     r0, [r2]" op))
         ((and (listp target) (eq (first target) :of))
          (let ((slot (second target)) (obj (third target)))
            (when (member obj '(:self "Self" self) :test #'equal)
              (format out "~&~8tldr     r2, =Self")
              (format out "~&~8tldr     r2, [r2]")
              (format out "~&~8t~a     r0, [r2, #~a]"
                      op (slot-symbol slot class-id)))))
         ((and (listp target) (eq (first target) :subscript))
          (format out "~&~8tmovs    r1, r0")
          (compile-arm7-load out (third target) class-id slot-table const-table pic-width-table 1)
          (when (= (or w 1) 2)
            (format out "~&~8tlsls    r0, r0, #1"))
          (format out "~&~8tldr     r2, =~a" (arm7-symbol (format nil "~a" (second target))))
          (format out "~&~8t~a     r1, [r2, r0]" op))
         (t (format out "~&~8t@ Unsupported set ~s" target))))))

(defun compile-arm7-perform (out stmt class-id slot-table type-table const-table pic-width-table)
  (let ((proc (getf (rest stmt) :procedure))
        (times (getf (rest stmt) :times))
        (until (getf (rest stmt) :until)))
    (cond
      (times
       (let ((lbl (arm7-label "perf")))
         (compile-arm7-load out times class-id slot-table const-table pic-width-table)
         (format out  "~&~8tmovs    r1, r0")
         (format out  "~&~a:" lbl)
         (format out  "~&~8tbl      ~a" (arm7-symbol (format nil "~a" proc)))
         (format out  "~&~8tsubs    r1, #1")
         (format out  "~&~8tbne     ~a" lbl)))
      (until
       (let ((lbl-loop (arm7-label "loop"))
             (lbl-end (arm7-label "end")))
         (format out  "~&~a:" lbl-loop)
         (compile-arm7-condition out until class-id slot-table type-table const-table pic-width-table lbl-end)
         (format out  "~&~8tbl      ~a" (arm7-symbol (format nil "~a" proc)))
         (format out  "~&~8tb       ~a" lbl-loop)
         (format out  "~&~a:" lbl-end)))
      (t
       (format out  "~&~8tbl      ~a" (arm7-symbol (format nil "~a" proc)))))))

(defun arm7-string-operand-address (operand)
  (cond
    ((and (listp operand) (eq (first operand) :refmod))
     (let* ((base (getf (rest operand) :base))
            (start (getf (rest operand) :start))
            (base-str (arm7-symbol (format nil "~a" base))))
       (if (and (integerp start) (= start 1))
           base-str
           (format nil "~a+~d" base-str (1- start)))))
    (t (arm7-symbol (format nil "~a" operand)))))

(defun compile-arm7-string-blt (out stmt class-id slot-table const-table)
  (declare (ignore class-id slot-table const-table))
  (let ((source (getf (rest stmt) :source))
        (dest (getf (rest stmt) :dest))
        (length (getf (rest stmt) :length)))
    (let ((len (or (%string-blt-refmod-length source)
                   (%string-blt-refmod-length dest)
                   length
                   64))
          (src-addr (arm7-string-operand-address source))
          (dst-addr (arm7-string-operand-address dest)))
      (format out  "~&~8tldr     r2, =~a" src-addr)
      (format out  "~&~8tldr     r1, =~a" dst-addr)
      (let ((lbl (arm7-label "blt")))
        (format out  "~&~8tmovs    r3, #~d" len)
        (format out  "~&~a:" lbl)
        (format out  "~&~8tldrb    r0, [r2]")
        (format out  "~&~8tstrb    r0, [r1]")
        (format out  "~&~8tadds    r2, #1")
        (format out  "~&~8tadds    r1, #1")
        (format out  "~&~8tsubs    r3, #1")
        (format out  "~&~8tbne     ~a" lbl)))))
