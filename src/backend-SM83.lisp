;; src/backend-SM83.lisp — Sharp SM83 (Game Boy) code generation backend
;;
;; The SM83 is the CPU in the Nintendo Game Boy, similar to Z80/8080.
;; Registers: A, B, C, D, E, H, L, BC, DE, HL, SP
;; Instructions: ld, add, sub, and, or, xor, cp, jr, jp, call, ret
;;
;; Output: RGBDS assembly syntax (ld a,[hl], jr nz, etc.)
;; Uses: A=accumulator, HL=ptr/result, BC=count, DE=dest-ptr/temp (prefer over stack)
(in-package :eightbol)

(defun sm83-symbol (name)
  "Convert EIGHTBOL identifier to SM83 assembly symbol (PascalCase). COBOL stabby-case supported."
  (cobol-id-to-assembly-symbol (format nil "~a" name)))

(defmethod compile-to-assembly (ast (cpu (eql :sm83)) output-stream)
  (unless (and (listp ast) (eq (first ast) :program))
    (error "EIGHTBOL/SM83: expected :program AST node, got ~s" (first ast)))
  (let* ((class-id (getf (rest ast) :class-id))
         (methods  (getf (rest ast) :methods)))
    (multiple-value-bind (slot-table type-table const-table service-bank-table usage-table sign-table
                                      pic-size-table pic-width-table pic-frac-bits-table
                                      pic-nybble-semantics-table)
        (load-copybook-tables class-id)
      (declare (ignore service-bank-table usage-table sign-table))
      (format output-stream
              "; ~a -- generated by EIGHTBOL for SM83 (Game Boy)~%; DO NOT EDIT -- regenerate from ~a.cob~2%"
              class-id class-id)
      (format output-stream  "~&SECTION \"~a\", ROM0~2%" class-id)
      (let ((*pic-frac-bits-table* pic-frac-bits-table)
            (*pic-nybble-semantics-table* pic-nybble-semantics-table))
        (dolist (method (ensure-list methods))
          (when (and (listp method) (eq (first method) :method))
            (compile-sm83-method output-stream method class-id
                                 slot-table type-table const-table pic-size-table pic-width-table)))))))

(defun compile-sm83-method (out method class-id slot-table type-table const-table pic-size-table pic-width-table)
  (let ((*slot-table* slot-table)
        (*type-table* type-table)
        (*const-table* const-table)
        (*pic-size-table* pic-size-table)
        (*pic-width-table* pic-width-table)
        (*class-id* class-id))
    (declare (special *slot-table* *type-table* *const-table* *pic-size-table*
                      *pic-width-table* *class-id*))
    (let ((method-id  (getf (rest method) :method-id))
          (statements (getf (rest method) :statements)))
      (format out "~&~%Method~a~a::"
              (sm83-symbol class-id) (sm83-symbol (format nil "~a" method-id)))
      (dolist (stmt (ensure-list statements))
        (compile-sm83-statement out stmt class-id slot-table type-table const-table pic-size-table pic-width-table))
      (format out "~&~8tret"))))

(defun compile-sm83-goto (out stmt class-id slot-table type-table const-table pic-size-table pic-width-table)
  "Emit SM83 GOTO: unconditional @code{jp}, or compare chain when @code{:depending-on} is set."
  (declare (ignore pic-size-table))
  (let ((target (getf (rest stmt) :target))
        (targets (getf (rest stmt) :targets))
        (dep (getf (rest stmt) :depending-on)))
    (if dep
        (let ((tgt-list (or targets (when target (list target)))))
          (when tgt-list
            (compile-sm83-load out dep class-id slot-table const-table pic-width-table 1)
            (format out "~&~8tld      b, a")
            (let ((n (length tgt-list)))
              (loop for i from 1 below n
                    do (format out "~&~8tld      a, b")
                       (format out "~&~8tcp      ~d" i)
                       (format out "~&~8tjp      z, ~a"
                               (sm83-symbol (format nil "~a" (nth (1- i) tgt-list)))))
              (format out "~&~8tjp      ~a"
                      (sm83-symbol (format nil "~a" (nth (1- n) tgt-list)))))))
        (format out "~&~8tjp      ~a"
                (sm83-symbol (format nil "~a" (or target (first targets))))))))

(defun compile-sm83-statement (out stmt class-id slot-table type-table const-table pic-size-table pic-width-table)
  (unless (and (listp stmt) (first stmt)) (return-from compile-sm83-statement))
  (emit-statement-source-comment out stmt)
  (ecase (first stmt)
    (:goback (format out "~&~8tret"))
    (:exit-method (format out "~&~8tret"))
    (:exit-program (format out "~&~8tret"))
    (:stop-run (format out "~&~8tret"))
    (:exit (format out "~&~8tret"))
    (:move (compile-sm83-move out stmt class-id slot-table const-table pic-width-table))
    (:invoke (compile-sm83-invoke out stmt class-id type-table pic-width-table))
    (:call (compile-sm83-call out stmt))
    (:if (compile-sm83-if out stmt class-id slot-table type-table const-table pic-size-table pic-width-table))
    (:add (compile-sm83-add out stmt class-id slot-table const-table pic-width-table))
    (:subtract (compile-sm83-subtract out stmt class-id slot-table const-table pic-width-table))
    (:compute (compile-sm83-compute out stmt class-id slot-table const-table pic-width-table))
    (:set (compile-sm83-set out stmt class-id slot-table const-table pic-width-table))
    (:log-fault (format out "~&~8t; LOG FAULT ~s" (getf (rest stmt) :code)))
    (:debug-break (format out "~&~8t; DEBUG BREAK ~s" (getf (rest stmt) :code)))
    (:perform (compile-sm83-perform out stmt class-id slot-table type-table const-table pic-width-table))
    (:string-blt (compile-sm83-string-blt out stmt class-id slot-table const-table))
    (:goto
     (format out "~&~8tjp      ~a" (sm83-symbol (format nil "~a" (or (getf (rest stmt) :target) (first (getf (rest stmt) :targets)))))))
    (:paragraph
     (let ((name (if (eq (first stmt) :paragraph)
                  (second stmt)
                  (or (getf (rest stmt) :paragraph) (second stmt)))))
       (when name (format out "~&~a:" (sm83-symbol (format nil "~a" name))))))
    (:evaluate
     (compile-sm83-evaluate out stmt class-id slot-table type-table const-table pic-size-table pic-width-table))
    (:inspect
     (compile-sm83-inspect out stmt class-id slot-table const-table pic-size-table pic-width-table))
    (:copy (error "EIGHTBOL: COPY ~s should have been expanded at lex time"
                  (getf (rest stmt) :name)))))

(defun sm83-expr-is-constant-p (expr const-table)
  (declare (ignore const-table))
  (or (numberp expr)
      (and (stringp expr) (constant-p expr))))

(defun sm83-value (expr &optional const-table)
  (declare (ignore const-table))
  (cond
    ((numberp expr) (format nil "~d" expr))
    ((and (stringp expr) (constant-p expr))
     (format nil "~d" (constant-value expr)))
    ((stringp expr) (bare-data-assembly-symbol expr *class-id*))
    ((eq expr :self) "Self")
    ((and (listp expr) (eq (first expr) :of))
     (sm83-symbol (format nil "~a-~a" (third expr) (second expr))))
    (t (format nil "~a" expr))))

(defun compile-sm83-load (out expr class-id slot-table const-table pic-width-table &optional (width (operand-width expr pic-width-table)))
  (cond
    ((numberp expr)
     (if (= (or width 1) 2)
         (format out "~&~8tld      hl, ~d" expr)
         (format out "~&~8tld      a, ~d" expr)))
    ((and (stringp expr) (constant-p expr))
     (if (= (or width 1) 2)
         (format out "~&~8tld      hl, ~d" (constant-value expr))
         (format out "~&~8tld      a, ~d" (constant-value expr))))
    ((stringp expr)
     (if (= (or width 1) 2)
         (format out "~&~8tld      hl, [~a]" (bare-data-assembly-symbol expr class-id))
         (format out "~&~8tld      a, [~a]" (bare-data-assembly-symbol expr class-id))))
    ((and (listp expr) (eq (first expr) :of))
     (let ((slot (second expr)) (obj (third expr)))
       (when (member obj '(:self "Self" self) :test #'equal)
         (format out "~&~8tld      hl, [Self]")
         (format out "~&~8tld      de, ~a" (slot-symbol slot class-id))
         (format out "~&~8tadd     hl, de")
         (if (= (or width 1) 2)
             (progn
               (format out "~&~8tld      a, [hl+]")
               (format out "~&~8tld      l, [hl]")
               (format out "~&~8tld      h, a"))
             (format out "~&~8tld      a, [hl]")))))
    ((and (listp expr) (eq (first expr) :subscript))
     (compile-sm83-load out (third expr) class-id slot-table const-table pic-width-table 1)
     (format out "~&~8tld      c, a")
     (format out "~&~8tld      b, 0")
     (format out "~&~8tld      hl, ~a" (bare-data-assembly-symbol (second expr) class-id))
     (format out "~&~8tadd     hl, bc")
     (when (= (or width 1) 2)
       (format out "~&~8tadd     hl, bc"))
     (if (= (or width 1) 2)
         (progn
           (format out "~&~8tld      a, [hl+]")
           (format out "~&~8tld      l, [hl]")
           (format out "~&~8tld      h, a"))
         (format out "~&~8tld      a, [hl]")))
    ((and (listp expr) (eq (first expr) :shift-left))
     (let ((n (if (numberp (third expr)) (third expr) 1)))
       (compile-sm83-load out (second expr) class-id slot-table const-table pic-width-table)
       (dotimes (_ n) (format out "~&~8tadd     a, a"))))
    ((and (listp expr) (eq (first expr) :shift-right))
     (let ((n (if (numberp (third expr)) (third expr) 1)))
       (compile-sm83-load out (second expr) class-id slot-table const-table pic-width-table)
       (dotimes (_ n) (format out "~&~8tsrl     a"))))
    ((and (listp expr) (eq (first expr) :bit-and))
     (compile-sm83-load out (second expr) class-id slot-table const-table pic-width-table)
     (let ((rhs (third expr)))
       (if (sm83-expr-is-constant-p rhs const-table)
           (format out "~&~8tand     ~a" (sm83-value rhs const-table))
           (progn (format out "~&~8tld      b, a")
                  (compile-sm83-load out rhs class-id slot-table const-table pic-width-table)
                  (format out "~&~8tand     b")))))
    ((and (listp expr) (eq (first expr) :bit-or))
     (compile-sm83-load out (second expr) class-id slot-table const-table pic-width-table)
     (let ((rhs (third expr)))
       (if (sm83-expr-is-constant-p rhs const-table)
           (format out "~&~8tor      ~a" (sm83-value rhs const-table))
           (progn (format out "~&~8tld      b, a")
                  (compile-sm83-load out rhs class-id slot-table const-table pic-width-table)
                  (format out "~&~8tor      b")))))
    ((and (listp expr) (eq (first expr) :bit-xor))
     (compile-sm83-load out (second expr) class-id slot-table const-table pic-width-table)
     (let ((rhs (third expr)))
       (if (sm83-expr-is-constant-p rhs const-table)
           (format out "~&~8txor     ~a" (sm83-value rhs const-table))
           (progn (format out "~&~8tld      b, a")
                  (compile-sm83-load out rhs class-id slot-table const-table pic-width-table)
                  (format out "~&~8txor     b")))))
    ((and (listp expr) (eq (first expr) :bit-not))
     (compile-sm83-load out (second expr) class-id slot-table const-table pic-width-table)
     (format out "~&~8tcpl"))
    (t (format out "~&~8t; Unsupported load ~s" expr))))

(defun compile-sm83-move (out stmt class-id slot-table const-table pic-width-table)
  (let* ((from (getf (rest stmt) :from))
         (to-dest (getf (rest stmt) :to))
         (to-w (operand-width to-dest pic-width-table))
         (from-w (expression-operand-width from pic-width-table)))
    (backend-unsupported-operand-width :sm83 :move (max from-w to-w) 2)
    (compile-sm83-load out from class-id slot-table const-table pic-width-table)
    (cond
      ((stringp to-dest)
       (if (= (or to-w 1) 2)
           (format out "~&~8tld      [~a], hl" (bare-data-assembly-symbol to-dest class-id))
           (format out "~&~8tld      [~a], a" (bare-data-assembly-symbol to-dest class-id))))
      ((and (listp to-dest) (eq (first to-dest) :of))
       (let ((slot (second to-dest)) (obj (third to-dest)))
         (when (member obj '(:self "Self" self) :test #'equal)
           (if (= (or to-w 1) 2)
               (progn
                 (format out "~&~8tld      d, h")
                 (format out "~&~8tld      e, l")
                 (format out "~&~8tld      hl, [Self]")
                 (format out "~&~8tld      bc, ~a" (slot-symbol slot class-id))
                 (format out "~&~8tadd     hl, bc")
                 (format out "~&~8tld      [hl], e")
                 (format out "~&~8tinc     hl")
                 (format out "~&~8tld      [hl], d"))
               (progn
                 (format out "~&~8tld      hl, [Self]")
                 (format out "~&~8tld      de, ~a" (slot-symbol slot class-id))
                 (format out "~&~8tadd     hl, de")
                 (format out "~&~8tld      [hl], a"))))))
      ((and (listp to-dest) (eq (first to-dest) :subscript))
       (if (= (or to-w 1) 2)
           (progn
             (format out "~&~8tpush    hl")
             (compile-sm83-load out (third to-dest) class-id slot-table const-table pic-width-table 1)
             (format out "~&~8tld      c, a")
             (format out "~&~8tld      b, 0")
             (format out "~&~8tld      hl, ~a" (bare-data-assembly-symbol (second to-dest) class-id))
             (format out "~&~8tadd     hl, bc")
             (format out "~&~8tadd     hl, bc")
             (format out "~&~8tpop     de")
             (format out "~&~8tld      [hl], e")
             (format out "~&~8tinc     hl")
             (format out "~&~8tld      [hl], d"))
           (progn
             (format out "~&~8tpush    af")
             (compile-sm83-load out (third to-dest) class-id slot-table const-table pic-width-table 1)
             (format out "~&~8tld      c, a")
             (format out "~&~8tld      b, 0")
             (format out "~&~8tld      hl, ~a" (bare-data-assembly-symbol (second to-dest) class-id))
             (format out "~&~8tadd     hl, bc")
             (format out "~&~8tpop     af")
             (format out "~&~8tld      [hl], a"))))
      (t (format out "~&~8t; Unsupported store to ~s" to-dest)))))

(defun compile-sm83-invoke (out stmt class-id type-table pic-width-table)
  (let ((object (getf (rest stmt) :object))
        (method (getf (rest stmt) :method))
        (returning (getf (rest stmt) :returning)))
    (let ((method-sym (sm83-symbol (format nil "~a" method))))
      (cond
        ((member object '(:self "Self" self) :test #'equal)
         (format out "~&~8tcall    Invoke~a~a" (sm83-symbol class-id) method-sym))
        (t
         (let* ((obj-name (sm83-symbol (format nil "~a" object)))
                (obj-class (or (var-class obj-name) "Unknown")))
           (format out "~&~8tcall    Call~a~a" obj-class method-sym))))
      (when returning
        (let ((ret-w (operand-width returning pic-width-table)))
          (if (= (or ret-w 1) 2)
              (format out "~&~8tld      [~a], hl" (bare-data-assembly-symbol returning class-id))
              (format out "~&~8tld      [~a], a" (bare-data-assembly-symbol returning class-id))))))))

(defun compile-sm83-call (out stmt)
  (let ((target (getf (rest stmt) :target))
        (service (getf (rest stmt) :service))
        (library (getf (rest stmt) :library)))
    (format out "~&~8tcall    ~a" (sm83-symbol (format nil "~a" (or service target))))))

(defvar *sm83-label* 0)

(defun sm83-label (prefix)
  (format nil ".~a~d" prefix (incf *sm83-label*)))

(defun compile-sm83-if (out stmt class-id slot-table type-table const-table pic-size-table pic-width-table)
  (let ((condition (getf (rest stmt) :condition))
        (then-stmts (getf (rest stmt) :then))
        (else-stmts (getf (rest stmt) :else))
        (lbl-else (sm83-label "else"))
        (lbl-end (sm83-label "end")))
    (compile-sm83-condition out condition class-id slot-table type-table const-table pic-width-table lbl-else)
    (dolist (s (ensure-list then-stmts))
      (compile-sm83-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table))
    (when (and else-stmts (not (null else-stmts)))
      (format out "~&~8tjr      ~a" lbl-end))
    (format out "~&~a:" lbl-else)
    (when (and else-stmts (not (null else-stmts)))
      (dolist (s (ensure-list else-stmts))
        (compile-sm83-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table))
      (format out "~&~a:" lbl-end))))

(defun compile-sm83-condition (out condition class-id slot-table type-table const-table pic-width-table branch-label)
  (cond
    ((and (listp condition) (member (first condition) '(= equal < less > greater) :test #'eq))
     (let ((lhs (second condition)) (rhs (third condition)) (op (first condition))
           (w (max (or (operand-width lhs pic-width-table) 1)
                   (or (operand-width rhs pic-width-table) 1))))
       (if (= w 2)
           (progn
             (compile-sm83-load out lhs class-id slot-table const-table pic-width-table 2)
             (format out "~&~8tld      d, h")
             (format out "~&~8tld      e, l")
             (compile-sm83-load out rhs class-id slot-table const-table pic-width-table 2)
             (format out "~&~8tld      a, l")
             (format out "~&~8tsub     e")
             (format out "~&~8tld      l, a")
             (format out "~&~8tld      a, h")
             (format out "~&~8tsbc     d")
             (format out "~&~8tld      h, a")
             (ecase op
               ((= equal)
                (format out "~&~8tld      a, h")
                (format out "~&~8tor      l")
                (format out "~&~8tjr      nz, ~a" branch-label))
               ((< less)  (format out "~&~8tjr      nc, ~a" branch-label))
               ((> greater)
                (format out "~&~8tjr      c, ~a" branch-label)
                (format out "~&~8tjr      z, ~a" branch-label))))
           (progn
             (compile-sm83-load out lhs class-id slot-table const-table pic-width-table)
             (format out "~&~8tld      b, a")
             (compile-sm83-load out rhs class-id slot-table const-table pic-width-table)
             (format out "~&~8tcp      b")
             (ecase op
               ((= equal) (format out "~&~8tjr      nz, ~a" branch-label))
               ((< less)  (format out "~&~8tjr      nc, ~a" branch-label))
               ((> greater) (format out "~&~8tjr      c, ~a" branch-label)))))))
    ((and (listp condition) (eq (first condition) :is-zero))
     (let ((ex (second condition))
           (w (operand-width ex pic-width-table)))
       (compile-sm83-load out ex class-id slot-table const-table pic-width-table)
       (if (= (or w 1) 2)
           (progn
             (format out "~&~8tld      a, h")
             (format out "~&~8tor      l"))
           (format out "~&~8tor      a"))
       (format out "~&~8tjr      nz, ~a" branch-label)))
    ((and (listp condition) (eq (first condition) :is-not-zero))
     (let ((ex (second condition))
           (w (operand-width ex pic-width-table)))
       (compile-sm83-load out ex class-id slot-table const-table pic-width-table)
       (if (= (or w 1) 2)
           (progn
             (format out "~&~8tld      a, h")
             (format out "~&~8tor      l"))
           (format out "~&~8tor      a"))
       (format out "~&~8tjr      z, ~a" branch-label)))
    ((and (listp condition) (eq (first condition) :and))
     (compile-sm83-condition out (second condition) class-id slot-table type-table const-table pic-width-table branch-label)
     (compile-sm83-condition out (third condition) class-id slot-table type-table const-table pic-width-table branch-label))
    ((and (listp condition) (eq (first condition) :or))
     (let ((lbl-cond2 (sm83-label "or"))
           (lbl-skip (sm83-label "skip")))
       (compile-sm83-condition out (second condition) class-id slot-table type-table const-table pic-width-table lbl-cond2)
       (format out "~&~8tjr      ~a" lbl-skip)
       (format out "~&~a:" lbl-cond2)
       (compile-sm83-condition out (third condition) class-id slot-table type-table const-table pic-width-table branch-label)
       (format out "~&~a:" lbl-skip)))
    (t (error "EIGHTBOL: condition ~s not implemented" condition))))

;;; EVALUATE and INSPECT (delegate to Z80-style logic; SM83 syntax similar)
(defun compile-sm83-evaluate (out stmt class-id slot-table type-table const-table pic-size-table pic-width-table)
  (let ((subject (getf (rest stmt) :subject))
        (clauses (getf (rest stmt) :when-clauses))
        (lbl-end (sm83-label "eval")))
    (dolist (clause (ensure-list clauses))
      (cond
        ((eq (first clause) :when-other)
         (dolist (s (ensure-list (second clause)))
           (compile-sm83-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table)))
        ((eq (first clause) :when)
         (let ((phrases (second clause))
               (stmts (third clause))
               (lbl-next (sm83-label "when")))
           (cond
             ((eq phrases 'eightbol::any)
              (dolist (s (ensure-list stmts))
                (compile-sm83-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table))
              (format out "~&~8tjr      ~a" lbl-end))
             ((or (eq phrases 'eightbol::true) (equal phrases "TRUE"))
              (let ((subj-w (operand-width subject pic-width-table)))
                (compile-sm83-load out subject class-id slot-table const-table pic-width-table)
                (if (= (or subj-w 1) 2)
                    (progn (format out "~&~8tld      a, h")
                           (format out "~&~8tor      l"))
                    (format out "~&~8tor      a"))
                (format out "~&~8tjr      z, ~a" lbl-next))
              (dolist (s (ensure-list stmts))
                (compile-sm83-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table))
              (format out "~&~8tjr      ~a" lbl-end)
              (format out "~&~a:" lbl-next))
             ((or (eq phrases 'eightbol::false) (equal phrases "FALSE"))
              (let ((subj-w (operand-width subject pic-width-table)))
                (compile-sm83-load out subject class-id slot-table const-table pic-width-table)
                (if (= (or subj-w 1) 2)
                    (progn (format out "~&~8tld      a, h")
                           (format out "~&~8tor      l"))
                    (format out "~&~8tor      a"))
                (format out "~&~8tjr      nz, ~a" lbl-next))
              (dolist (s (ensure-list stmts))
                (compile-sm83-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table))
              (format out "~&~8tjr      ~a" lbl-end)
              (format out "~&~a:" lbl-next))
             ((and (listp phrases) (eq (first phrases) :not))
              (compile-sm83-load out subject class-id slot-table const-table pic-width-table)
              (format out "~&~8tld      b, a")
              (compile-sm83-load out (second phrases) class-id slot-table const-table pic-width-table)
              (format out "~&~8tcp      b")
              (format out "~&~8tjr      z, ~a" lbl-next)
              (dolist (s (ensure-list stmts))
                (compile-sm83-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table))
              (format out "~&~8tjr      ~a" lbl-end)
              (format out "~&~a:" lbl-next))
             ((and (listp phrases) (member (first phrases) '(:through :thru)))
              (let ((lo (second phrases)) (hi (third phrases)))
                (compile-sm83-load out subject class-id slot-table const-table pic-width-table)
                (format out "~&~8tld      b, a")
                (compile-sm83-load out lo class-id slot-table const-table pic-width-table)
                (format out "~&~8tcp      b")
                (format out "~&~8tjr      c, ~a" lbl-next)
                (compile-sm83-load out hi class-id slot-table const-table pic-width-table)
                (format out "~&~8tld      c, a")
                (format out "~&~8tld      a, b")
                (format out "~&~8tcp      c")
                (format out "~&~8tjr      nc, ~a" lbl-next)
                (dolist (s (ensure-list stmts))
                  (compile-sm83-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table))
                (format out "~&~8tjr      ~a" lbl-end)
                (format out "~&~a:" lbl-next)))
             (t
              (let ((phrase-expr (if (listp phrases) (second phrases) phrases)))
                (compile-sm83-load out subject class-id slot-table const-table pic-width-table)
                (format out "~&~8tld      b, a")
                (compile-sm83-load out phrase-expr class-id slot-table const-table pic-width-table)
                (format out "~&~8tcp      b")
                (format out "~&~8tjr      nz, ~a" lbl-next)
                (dolist (s (ensure-list stmts))
                  (compile-sm83-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table))
                (format out "~&~8tjr      ~a" lbl-end)
                (format out "~&~a:" lbl-next))))))))
    (format out "~&~a:" lbl-end)))

(defun compile-sm83-inspect (out stmt class-id slot-table const-table pic-size-table pic-width-table)
  (let ((target (getf (rest stmt) :target))
        (tally (getf (rest stmt) :tallying))
        (conv-from (getf (rest stmt) :converting))
        (conv-to (getf (rest stmt) :to))
        (repl-by (getf (rest stmt) :by)))
    (let ((tgt-sym (sm83-symbol (format nil "~a" target))))
      (cond
        (tally
         (let ((tally-sym (sm83-symbol (format nil "~a" tally))))
           (format out "~&~8t; INSPECT ~a TALLYING ~a FOR CHARACTERS" target tally)
           (format out "~&~8tld      hl, ~a" tgt-sym)
           (let ((lbl (sm83-label "tally")) (lbl-done (sm83-label "tallyd")) (lbl-skip (sm83-label "tallys")))
             (format out "~&~a:" lbl)
             (format out "~&~8tld      a, [hl]")
             (format out "~&~8tor      a")
             (format out "~&~8tjr      z, ~a" lbl-done)
             (format out "~&~8tld      a, [~a]" tally-sym)
             (format out "~&~8tinc     a")
             (format out "~&~8tld      [~a], a" tally-sym)
             (format out "~&~a:" lbl-skip)
             (format out "~&~8tinc     hl")
             (format out "~&~8tjr      ~a" lbl)
             (format out "~&~a:" lbl-done)))
        (conv-from
         (format out "~&~8t; INSPECT ~a CONVERTING" target)
         (format out "~&~8tld      hl, ~a" tgt-sym)
         (let ((lbl (sm83-label "insp")) (lbl-next (sm83-label "inspn")) (lbl-done (sm83-label "inspd")))
           (format out "~&~a:" lbl)
           (format out "~&~8tld      a, [hl]")
           (format out "~&~8tor      a")
           (format out "~&~8tjr      z, ~a" lbl-done)
           (if (sm83-expr-is-constant-p conv-from const-table)
               (format out "~&~8tcp      ~a" (sm83-value conv-from const-table))
               (progn (format out "~&~8tld      b, a")
                      (compile-sm83-load out conv-from class-id slot-table const-table pic-width-table 1)
                      (format out "~&~8tcp      b")))
           (format out "~&~8tjr      nz, ~a" lbl-next)
           (compile-sm83-load out conv-to class-id slot-table const-table pic-width-table 1)
           (format out "~&~8tld      [hl], a")
           (format out "~&~a:" lbl-next)
           (format out "~&~8tinc     hl")
           (format out "~&~8tjr      ~a" lbl)
           (format out "~&~a:" lbl-done)))
        (repl-by
         (let ((len (or (pic-size (format nil "~a" target) pic-size-table) 64)))
           (format out "~&~8t; INSPECT ~a REPLACING CHARACTERS BY ~a" target repl-by)
           (compile-sm83-load out repl-by class-id slot-table const-table pic-width-table 1)
           (format out "~&~8tld      hl, ~a" tgt-sym)
           (let ((lbl (sm83-label "insp")))
             (format out "~&~8tld      b, ~d" len)
             (format out "~&~a:" lbl)
             (format out "~&~8tld      [hl], a")
             (format out "~&~8tinc     hl")
             (format out "~&~8tdec     b")
             (format out "~&~8tjr      nz, ~a" lbl)))))))))

(defun compile-sm83-add (out stmt class-id slot-table const-table pic-width-table)
  (let* ((from (getf (rest stmt) :from))
         (to-op (getf (rest stmt) :to))
         (giving (getf (rest stmt) :giving))
         (result (or giving (and (stringp to-op) to-op)))
         (w (max (operand-width (or result to-op) pic-width-table)
                 (expression-operand-width from pic-width-table)
                 (operand-width to-op pic-width-table))))
    (backend-unsupported-operand-width :sm83 :add w 2)
    (if (= (or w 1) 2)
        (progn
          ;; 16-bit: use DE for temp (ld d,h ld e,l) — SM83 has no ex
          (compile-sm83-load out to-op class-id slot-table const-table pic-width-table 2)
          (format out "~&~8tld      d, h")
          (format out "~&~8tld      e, l")
          (compile-sm83-load out from class-id slot-table const-table pic-width-table 2)
          (format out "~&~8tadd     hl, de")
          (when result
            (format out "~&~8tld      [~a], hl" (bare-data-assembly-symbol result class-id))))
        (progn
          (compile-sm83-load out to-op class-id slot-table const-table pic-width-table)
          (format out "~&~8tld      b, a")
          (compile-sm83-load out from class-id slot-table const-table pic-width-table)
          (format out "~&~8tadd     b")
          (let ((dest (or giving (and (stringp to-op) to-op))))
            (when dest
              (format out "~&~8tld      [~a], a" (bare-data-assembly-symbol dest class-id))))))))

(defun compile-sm83-subtract (out stmt class-id slot-table const-table pic-width-table)
  (let* ((from (getf (rest stmt) :from))
         (from-target (getf (rest stmt) :from-target))
         (giving (getf (rest stmt) :giving))
         (dest (or giving from-target))
         (w (max (operand-width dest pic-width-table)
                 (expression-operand-width from pic-width-table)
                 (operand-width from-target pic-width-table))))
    (backend-unsupported-operand-width :sm83 :subtract w 2)
    (if (= (or w 1) 2)
        (progn
          ;; 16-bit: DE=from_target, HL=from; swap so HL=from_target, DE=from; then HL-DE
          (compile-sm83-load out from-target class-id slot-table const-table pic-width-table 2)
          (format out "~&~8tld      d, h")
          (format out "~&~8tld      e, l")
          (compile-sm83-load out from class-id slot-table const-table pic-width-table 2)
          (format out "~&~8tld      a, l")
          (format out "~&~8tld      l, e")
          (format out "~&~8tld      e, a")
          (format out "~&~8tld      a, h")
          (format out "~&~8tld      h, d")
          (format out "~&~8tld      d, a")
          (format out "~&~8tld      a, l")
          (format out "~&~8tsub     e")
          (format out "~&~8tld      l, a")
          (format out "~&~8tld      a, h")
          (format out "~&~8tsbc     d")
          (format out "~&~8tld      h, a")
          (format out "~&~8tld      [~a], hl" (bare-data-assembly-symbol dest class-id)))
        (progn
          (compile-sm83-load out from-target class-id slot-table const-table pic-width-table)
          (format out "~&~8tld      b, a")
          (compile-sm83-load out from class-id slot-table const-table pic-width-table)
          (format out "~&~8tld      c, a")
          (format out "~&~8tld      a, b")
          (format out "~&~8tsub     c")
          (format out "~&~8tld      [~a], a" (bare-data-assembly-symbol dest class-id))))))

(defun compile-sm83-compute (out stmt class-id slot-table const-table pic-width-table)
  (let* ((target (getf (rest stmt) :target))
         (expr (getf (rest stmt) :expression))
         (w (max (operand-width target pic-width-table)
                 (expression-operand-width expr pic-width-table))))
    (backend-unsupported-operand-width :sm83 :compute w 2)
    (compile-sm83-load out expr class-id slot-table const-table pic-width-table)
    (if (= (or w 1) 2)
        (format out "~&~8tld      [~a], hl" (bare-data-assembly-symbol target class-id))
        (format out "~&~8tld      [~a], a" (bare-data-assembly-symbol target class-id)))))

(defun compile-sm83-set (out stmt class-id slot-table const-table pic-width-table)
  (let* ((target (getf (rest stmt) :target))
         (value (getf (rest stmt) :value))
         (up-by (getf (rest stmt) :up-by))
         (down-by (getf (rest stmt) :down-by))
         (by-expr (getf (rest stmt) :by))
         (address-of (getf (rest stmt) :address-of))
         (to-self (getf (rest stmt) :to-self))
         (w (operand-width (or target to-self up-by down-by) pic-width-table)))
    (cond
      (up-by
       (compile-sm83-add out (list :add :from by-expr :to up-by :giving nil) class-id slot-table const-table pic-width-table))
      (down-by
       (compile-sm83-subtract out (list :subtract :from by-expr :from-target down-by :giving nil) class-id slot-table const-table pic-width-table))
      ((and address-of target)
       (let ((src address-of) (dest target))
         (cond
           ((and (listp src) (eq :of (first src))
                 (member (third src) '(:self "Self" self) :test #'equal))
            (format out "~&~8tld      hl, [Self]")
            (format out "~&~8tld      de, ~a" (slot-symbol (second src) class-id))
            (format out "~&~8tadd     hl, de"))
           ((stringp src)
            (format out "~&~8tld      hl, ~a" (sm83-symbol src)))
           (t (format out "~&~8t; Unsupported SET ADDRESS OF source ~s" src)))
         (cond
           ((stringp dest)
            (if (= (or w 1) 2)
                (format out "~&~8tld      [~a], hl" (sm83-symbol dest))
                (progn
                  (format out "~&~8tld      a, l")
                  (format out "~&~8tld      [~a], a" (sm83-symbol dest)))))
           (t (format out "~&~8t; Unsupported SET ADDRESS OF target ~s" dest)))))
      (to-self
       (format out "~&~8tld      hl, [Self]")
       (cond
         ((stringp to-self)
          (if (= (or w 1) 2)
              (format out "~&~8tld      [~a], hl" (sm83-symbol to-self))
              (progn
                (format out "~&~8tld      a, l")
                (format out "~&~8tld      [~a], a" (sm83-symbol to-self)))))
         (t (format out "~&~8t; Unsupported SET TO SELF destination ~s" to-self))))
      (t
       (compile-sm83-load out value class-id slot-table const-table pic-width-table)
       (cond
      ((stringp target)
       (if (= (or w 1) 2)
           (format out "~&~8tld      [~a], hl" (sm83-symbol target))
           (format out "~&~8tld      [~a], a" (sm83-symbol target))))
      ((and (listp target) (eq (first target) :of))
       (let ((slot (second target)) (obj (third target)))
         (when (member obj '(:self "Self" self) :test #'equal)
           (if (= (or w 1) 2)
               (progn
                 (format out "~&~8tpush    hl")
                 (format out "~&~8tld      hl, [Self]")
                 (format out "~&~8tld      de, ~a" (slot-symbol slot class-id))
                 (format out "~&~8tadd     hl, de")
                 (format out "~&~8tpop     de")
                 (format out "~&~8tld      [hl], e")
                 (format out "~&~8tinc     hl")
                 (format out "~&~8tld      [hl], d"))
               (progn
                 (format out "~&~8tld      hl, [Self]")
                 (format out "~&~8tld      de, ~a" (slot-symbol slot class-id))
                 (format out "~&~8tadd     hl, de")
                 (format out "~&~8tld      [hl], a"))))))
      ((and (listp target) (eq (first target) :subscript))
       (if (= (or w 1) 2)
           (progn
             (format out "~&~8tld      d, h")
             (format out "~&~8tld      e, l")
             (compile-sm83-load out (third target) class-id slot-table const-table pic-width-table 1)
             (format out "~&~8tld      c, a")
             (format out "~&~8tld      b, 0")
             (format out "~&~8tld      hl, ~a" (sm83-symbol (format nil "~a" (second target))))
             (format out "~&~8tadd     hl, bc")
             (format out "~&~8tadd     hl, bc")
             (format out "~&~8tld      [hl], e")
             (format out "~&~8tinc     hl")
             (format out "~&~8tld      [hl], d"))
           (progn
             (format out "~&~8tld      b, a")
             (compile-sm83-load out (third target) class-id slot-table const-table pic-width-table 1)
             (format out "~&~8tld      c, a")
             (format out "~&~8tld      a, b")
             (format out "~&~8tld      b, 0")
             (format out "~&~8tld      hl, ~a" (sm83-symbol (format nil "~a" (second target))))
             (format out "~&~8tadd     hl, bc")
             (format out "~&~8tld      [hl], a"))))
      (t (format out "~&~8t; Unsupported set ~s" target)))))))

(defun compile-sm83-perform (out stmt class-id slot-table type-table const-table pic-width-table)
  (let ((proc (getf (rest stmt) :procedure))
        (times (getf (rest stmt) :times))
        (until (getf (rest stmt) :until)))
    (cond
      (times
       (let ((lbl (sm83-label "perf"))
             (lbl-done (sm83-label "perfd"))
             (times-w (operand-width times pic-width-table)))
         (compile-sm83-load out times class-id slot-table const-table pic-width-table)
         (if (= (or times-w 1) 2)
             (progn
               (format out "~&~8tld      b, h")
               (format out "~&~8tld      c, l")
               (format out "~&~a:" lbl)
               (format out "~&~8tld      a, b")
               (format out "~&~8tor      c")
               (format out "~&~8tjr      z, ~a" lbl-done)
               (format out "~&~8tpush    bc")
               (format out "~&~8tcall    ~a" (sm83-symbol (format nil "~a" proc)))
               (format out "~&~8tpop     bc")
               (format out "~&~8tdec     bc")
               (format out "~&~8tjr      ~a" lbl)
               (format out "~&~a:" lbl-done))
             (progn
               (format out "~&~8tld      b, a")
               (format out "~&~a:" lbl)
               (format out "~&~8tpush    bc")
               (format out "~&~8tcall    ~a" (sm83-symbol (format nil "~a" proc)))
               (format out "~&~8tpop     bc")
               (format out "~&~8tdec     b")
               (format out "~&~8tjr      nz, ~a" lbl)))))
      (until
       (let ((lbl-loop (sm83-label "loop"))
             (lbl-end (sm83-label "end")))
         (format out "~&~a:" lbl-loop)
         (compile-sm83-condition out until class-id slot-table type-table const-table pic-width-table lbl-end)
         (format out "~&~8tcall    ~a" (sm83-symbol (format nil "~a" proc)))
         (format out "~&~8tjr      ~a" lbl-loop)
         (format out "~&~a:" lbl-end)))
      (t
       (format out "~&~8tcall    ~a" (sm83-symbol (format nil "~a" proc)))))))

(defun sm83-string-operand-address (operand)
  (cond
    ((and (listp operand) (eq (first operand) :refmod))
     (let* ((base (getf (rest operand) :base))
            (start (getf (rest operand) :start))
            (base-str (sm83-symbol (format nil "~a" base))))
       (if (and (integerp start) (= start 1))
           base-str
           (format nil "~a+~d" base-str (1- start)))))
    (t (sm83-symbol (format nil "~a" operand)))))

(defun compile-sm83-string-blt (out stmt class-id slot-table const-table)
  (let ((source (getf (rest stmt) :source))
        (dest (getf (rest stmt) :dest))
        (length (getf (rest stmt) :length)))
    (let ((len (or (%string-blt-refmod-length source)
                   (%string-blt-refmod-length dest)
                   length 64))
          (src-addr (sm83-string-operand-address source))
          (dst-addr (sm83-string-operand-address dest)))
      (format out "~&~8tld      hl, ~a" src-addr)
      (format out "~&~8tld      de, ~a" dst-addr)
      (let ((lbl (sm83-label "blt")))
        (format out "~&~8tld      bc, ~d" len)
        (format out "~&~a:" lbl)
        (format out "~&~8tld      a, [hl+]")
        (format out "~&~8tld      [de], a")
        (format out "~&~8tinc     de")
        (format out "~&~8tdec     bc")
        (format out "~&~8tld      a, b")
        (format out "~&~8tor      c")
        (format out "~&~8tjr      nz, ~a" lbl)))))
