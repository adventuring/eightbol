;; src/backend-F8.lisp — Fairchild F8 (Channel F) code generation backend
;;
;; Emits Fairchild F8 assembly (Turner/Fairchild mnemonics): A accumulator,
;; DC0 data counter, LM/ST, DCI, LI/AI/CI, LR H/DC0, branches BR/BZ/BNZ/etc.,
;; PI/POP subroutine call/return. 16-bit values use scratch 10 (lo) and 11 (hi).
;; Scratch 6–9 are codegen temps.  See also: eightbol-compile +cpu-display-names+.
(in-package :eightbol)

(defun f8-symbol (name)
  "Convert EIGHTBOL identifier to F8 assembly symbol (PascalCase). COBOL stabby-case supported."
  (pascal-case (format nil "~a" name)))

(defun %f8-self-pointer-to-dc0 (out)
  "*Self at label Self → DC0 (16-bit pointer from memory, little-endian)."
  (format out "~&~10tDCI     Self")
  (format out "~&~10tLM")
  (format out "~&~10tLR      10, A")
  (format out "~&~10tLM")
  (format out "~&~10tLR      11, A")
  (format out "~&~10tLR      H, DC0"))

(defun %f8-dc0-add-slot-offset (out slot-name class-id)
  "Add slot byte offset (symbol) to DC0 via LI + ADC."
  (format out "~&~10tLI      ~a" (slot-symbol slot-name class-id))
  (format out "~&~10tADC"))

(defun %f8-dc0-to-10-11 (out)
  "Copy 16-bit DC0 into scratch 10 (lo) and 11 (hi) via @code{LR DC0, H} (Turner F8 manual)."
  (format out "~&~10tLR      DC0, H"))

(defun %f8-load-byte-at-dc0 (out)
  (format out "~&~10tLM"))

(defun %f8-store-a-via-dc0 (out)
  (format out "~&~10tST"))

(defun %f8-dc0-bump-by-count (out count-reg lbl-loop lbl-done)
  "Add 1 to DC0 COUNT-REG times (COUNT-REG must be scratch 0..11)."
  (format out "~&~a:" lbl-loop)
  (format out "~&~10tLR      A, ~d" count-reg)
  (format out "~&~10tCI      0")
  (format out "~&~10tBZ      ~a" lbl-done)
  (format out "~&~10tDS      ~d" count-reg)
  (format out "~&~10tLI      1")
  (format out "~&~10tADC")
  (format out "~&~10tBR      ~a" lbl-loop)
  (format out "~&~a:" lbl-done))

(defmethod compile-to-assembly (ast (cpu (eql :f8)) output-stream)
  (unless (and (listp ast) (eq (first ast) :program))
    (error "EIGHTBOL/F8: expected :program AST node, got ~s" (first ast)))
  (let* ((class-id (getf (rest ast) :class-id))
         (methods (getf (rest ast) :methods)))
    (multiple-value-bind (slot-table type-table const-table service-bank-table
                                      usage-table sign-table pic-size-table pic-width-table pic-frac-bits-table
                                      pic-nybble-semantics-table)
        (load-copybook-tables class-id)
      (let ((*usage-table* usage-table)
            (*sign-table* sign-table)
            (*pic-frac-bits-table* pic-frac-bits-table)
            (*pic-nybble-semantics-table* pic-nybble-semantics-table))
        (declare (ignore service-bank-table sign-table))
        (format output-stream
                ";;; ~a -- generated by EIGHTBOL for F8 (Channel F)~%;;; DO NOT EDIT -- regenerate from ~a.cob~2%"
                class-id class-id)
        (dolist (method (ensure-list methods))
          (when (and (listp method) (eq (first method) :method))
            (compile-f8-method output-stream method class-id
                                 slot-table type-table const-table pic-size-table pic-width-table)))))))

(defun compile-f8-method (out method class-id slot-table type-table const-table pic-size-table pic-width-table)
  (let ((*slot-table* slot-table)
        (*type-table* type-table)
        (*const-table* const-table)
        (*pic-size-table* pic-size-table)
        (*pic-width-table* pic-width-table)
        (*class-id* class-id))
    (declare (special *slot-table* *type-table* *const-table* *pic-size-table*
                      *pic-width-table* *class-id*))
    (let* ((method-id (getf (rest method) :method-id))
           (stmts (ensure-list (getf (rest method) :statements)))
           (last (car (last stmts))))
      (format out "~&~%Method~a~a:"
              (f8-symbol class-id) (f8-symbol (format nil "~a" method-id)))
      (dolist (stmt stmts)
        (compile-f8-statement out stmt class-id slot-table type-table const-table
                              pic-size-table pic-width-table))
      (unless (and last (listp last)
                   (member (first last)
                           '(:goback :exit-method :exit-program :exit :stop-run)))
        (format out "~&~10tPOP")))))

(defun compile-f8-goto (out stmt class-id slot-table type-table const-table pic-size-table pic-width-table)
  "Emit F8 GOTO: unconditional @code{JMP}, or compare/@code{BZ} chain when @code{:depending-on} is set."
  (declare (ignore pic-size-table))
  (let ((target (getf (rest stmt) :target))
        (targets (getf (rest stmt) :targets))
        (dep (getf (rest stmt) :depending-on)))
    (if dep
        (let ((tgt-list (or targets (when target (list target)))))
          (when tgt-list
            (compile-f8-load out dep class-id slot-table const-table pic-width-table 1)
            (format out "~&~10tLR      8, A")
            (let ((n (length tgt-list)))
              (loop for i from 1 below n
                    do (format out "~&~10tLR      A, 8")
                       (format out "~&~10tCI      ~d" i)
                       (format out "~&~10tBZ      ~a"
                               (f8-symbol (format nil "~a" (nth (1- i) tgt-list)))))
              (format out "~&~10tJMP     ~a"
                      (f8-symbol (format nil "~a" (nth (1- n) tgt-list)))))))
        (format out "~&~10tJMP     ~a"
                (f8-symbol (format nil "~a" (or target (first targets))))))))

(defun compile-f8-statement (out stmt class-id slot-table type-table const-table pic-size-table pic-width-table)
  (unless (and (listp stmt) (first stmt)) (return-from compile-f8-statement))
  (emit-statement-source-comment out stmt)
  (ecase (first stmt)
    (:goback (format out "~&~10tPOP"))
    (:exit-method (format out "~&~10tPOP"))
    (:exit-program (format out "~&~10tPOP"))
    (:stop-run (format out "~&~10tPOP"))
    (:exit (format out "~&~10tPOP"))
    (:move (compile-f8-move out stmt class-id slot-table const-table pic-width-table))
    (:invoke (compile-f8-invoke out stmt class-id slot-table type-table const-table pic-width-table))
    (:call (compile-f8-call out stmt))
    (:if (compile-f8-if out stmt class-id slot-table type-table const-table pic-size-table pic-width-table))
    (:add (compile-f8-add out stmt class-id slot-table const-table pic-width-table))
    (:subtract (compile-f8-subtract out stmt class-id slot-table const-table pic-width-table))
    (:compute (compile-f8-compute out stmt class-id slot-table const-table pic-width-table))
    (:set (compile-f8-set out stmt class-id slot-table const-table pic-width-table))
    (:log-fault (format out "~&~10t;; LOG FAULT ~s" (getf (rest stmt) :code)))
    (:debug-break (format out "~&~10t;; DEBUG BREAK ~s" (getf (rest stmt) :code)))
    (:perform (compile-f8-perform out stmt class-id slot-table type-table const-table pic-width-table))
    (:string-blt (compile-f8-string-blt out stmt class-id slot-table const-table))
    (:goto
     (compile-f8-goto out stmt class-id slot-table type-table const-table pic-size-table pic-width-table))
    (:paragraph
     (let ((name (if (eq (first stmt) :paragraph)
                  (second stmt)
                  (or (getf (rest stmt) :paragraph) (second stmt)))))
       (when name (format out "~&~a:" (f8-symbol (format nil "~a" name))))))
    (:evaluate
     (compile-f8-evaluate out stmt class-id slot-table type-table const-table pic-size-table pic-width-table))
    (:inspect
     (compile-f8-inspect out stmt class-id slot-table const-table pic-size-table pic-width-table))
    (:copy (error "EIGHTBOL: COPY ~s should have been expanded at lex time"
                  (getf (rest stmt) :name)))))

(defun compile-f8-load (out expr class-id slot-table const-table pic-width-table
                      &optional (width (operand-width expr pic-width-table)))
  "Load EXPR into A (width 1) or scratch 10–11 lo/hi (width 2)."
  (declare (ignore slot-table))
  (labels ((load-word-imm (v)
             (format out "~&~10tLI      ~d" (logand v #xff))
             (format out "~&~10tLR      10, A")
             (format out "~&~10tLI      ~d" (logand (ash v -8) #xff))
             (format out "~&~10tLR      11, A")))
    (cond
      ((numberp expr)
       (if (= (or width 1) 2)
           (load-word-imm expr)
           (format out "~&~10tLI      ~d" expr)))
      ((and (stringp expr) (constant-p expr))
       (compile-f8-load out (constant-value expr) class-id slot-table const-table
                          pic-width-table width))
      ((stringp expr)
       (if (= (or width 1) 2)
           (progn
             (format out "~&~10tDCI     ~a" (slot-symbol expr class-id))
             (%f8-load-byte-at-dc0 out)
             (format out "~&~10tLR      10, A")
             (%f8-load-byte-at-dc0 out)
             (format out "~&~10tLR      11, A"))
           (progn
             (format out "~&~10tDCI     ~a" (slot-symbol expr class-id))
             (%f8-load-byte-at-dc0 out))))
      ((and (listp expr) (eq (first expr) :of))
       (let ((slot (second expr)) (obj (third expr)))
         (when (member obj '(:self "Self" self) :test #'equal)
           (%f8-self-pointer-to-dc0 out)
           (%f8-dc0-add-slot-offset out slot class-id)
           (if (= (or width 1) 2)
               (progn
                 (%f8-load-byte-at-dc0 out)
                 (format out "~&~10tLR      10, A")
                 (%f8-load-byte-at-dc0 out)
                 (format out "~&~10tLR      11, A"))
               (%f8-load-byte-at-dc0 out)))))
      ((and (listp expr) (eq (first expr) :subscript))
       (compile-f8-load out (third expr) class-id slot-table const-table pic-width-table 1)
       (format out "~&~10tLR      6, A")
       (when (= (or width 1) 2)
         (format out "~&~10tLR      A, 6")
         (format out "~&~10tSL      1")
         (format out "~&~10tLR      6, A"))
       (format out "~&~10tDCI     ~a" (slot-symbol (second expr) class-id))
       (let ((lp (f8-label "ix"))
             (dn (f8-label "ixd")))
         (%f8-dc0-bump-by-count out 6 lp dn))
       (if (= (or width 1) 2)
           (progn
             (%f8-load-byte-at-dc0 out)
             (format out "~&~10tLR      10, A")
             (%f8-load-byte-at-dc0 out)
             (format out "~&~10tLR      11, A"))
           (%f8-load-byte-at-dc0 out)))
      ((and (listp expr) (eq (first expr) :shift-left))
       (let ((n (if (numberp (third expr)) (third expr) 1)))
         (compile-f8-load out (second expr) class-id slot-table const-table pic-width-table)
         (dotimes (_ n) (format out "~&~10tSL      1"))))
      ((and (listp expr) (eq (first expr) :shift-right))
       (let ((n (if (numberp (third expr)) (third expr) 1)))
         (compile-f8-load out (second expr) class-id slot-table const-table pic-width-table)
         (dotimes (_ n) (format out "~&~10tSR      1"))))
      ((and (listp expr) (eq (first expr) :bit-and))
       (compile-f8-load out (second expr) class-id slot-table const-table pic-width-table)
       (let ((rhs (third expr)))
         (if (f8-expr-is-constant-p rhs)
             (format out "~&~10tNI      ~a" (f8-value rhs))
             (progn (format out "~&~10tLR      8, A")
                    (compile-f8-load out rhs class-id slot-table const-table pic-width-table)
                    (format out "~&~10tNS      8")))))
      ((and (listp expr) (eq (first expr) :bit-or))
       (compile-f8-load out (second expr) class-id slot-table const-table pic-width-table)
       (let ((rhs (third expr)))
         (if (f8-expr-is-constant-p rhs)
             (format out "~&~10tOI      ~a" (f8-value rhs))
             (progn
               (format out "~&~10tLR      8, A")
               (compile-f8-load out rhs class-id slot-table const-table pic-width-table)
               ;; a|b = ~(~a & ~b)  (De Morgan; one byte.)
               (format out "~&~10tCOM")
               (format out "~&~10tLR      9, A")
               (format out "~&~10tLR      A, 8")
               (format out "~&~10tCOM")
               (format out "~&~10tNS      9")
               (format out "~&~10tCOM")))))
      ((and (listp expr) (eq (first expr) :bit-xor))
       (compile-f8-load out (second expr) class-id slot-table const-table pic-width-table)
       (let ((rhs (third expr)))
         (if (f8-expr-is-constant-p rhs)
             (format out "~&~10tXI      ~a" (f8-value rhs))
             (progn (format out "~&~10tLR      8, A")
                    (compile-f8-load out rhs class-id slot-table const-table pic-width-table)
                    (format out "~&~10tXS      8")))))
      ((and (listp expr) (eq (first expr) :bit-not))
       (compile-f8-load out (second expr) class-id slot-table const-table pic-width-table)
       (format out "~&~10tCOM"))
      (t (format out "~&~10t;; Unsupported load ~s" expr)))))

;;; NOTE: bit-or with variable RHS is approximated; prefer OI with constant.

(defun %f8-store-dest (out class-id slot-table const-table dest pic-width-table &optional word-pair-p)
  "Store value: A (byte) or scratch 10–11 (word if WORD-PAIR-P) to DEST."
  (let ((w (operand-width dest pic-width-table)))
    (cond
      ((stringp dest)
       (if (or word-pair-p (= (or w 1) 2))
           (progn
             (format out "~&~10tDCI     ~a" (slot-symbol dest class-id))
             (format out "~&~10tLR      A, 10")
             (%f8-store-a-via-dc0 out)
             (format out "~&~10tLR      A, 11")
             (%f8-store-a-via-dc0 out))
           (progn
             (format out "~&~10tDCI     ~a" (slot-symbol dest class-id))
             (%f8-store-a-via-dc0 out))))
      ((and (listp dest) (eq (first dest) :of))
       (let ((slot (second dest)) (obj (third dest)))
         (when (member obj '(:self "Self" self) :test #'equal)
           (%f8-self-pointer-to-dc0 out)
           (%f8-dc0-add-slot-offset out slot class-id)
           (if (or word-pair-p (= (or w 1) 2))
               (progn
                 (format out "~&~10tLR      A, 10")
                 (%f8-store-a-via-dc0 out)
                 (format out "~&~10tLR      A, 11")
                 (%f8-store-a-via-dc0 out))
               (%f8-store-a-via-dc0 out)))))
      ((and (listp dest) (eq (first dest) :subscript))
       (when word-pair-p
         (format out "~&~10tLR      12, 10")
         (format out "~&~10tLR      13, 11"))
       (unless word-pair-p
         (format out "~&~10tLR      12, A"))
       (compile-f8-load out (third dest) class-id slot-table const-table pic-width-table 1)
       (format out "~&~10tLR      6, A")
       (when (= (or w 1) 2)
         (format out "~&~10tLR      A, 6")
         (format out "~&~10tSL      1")
         (format out "~&~10tLR      6, A"))
       (format out "~&~10tDCI     ~a" (slot-symbol (second dest) class-id))
       (let ((lp (f8-label "stx"))
             (dn (f8-label "std")))
         (%f8-dc0-bump-by-count out 6 lp dn))
       (if (or word-pair-p (= (or w 1) 2))
           (progn
             (format out "~&~10tLR      A, 12")
             (%f8-store-a-via-dc0 out)
             (format out "~&~10tLR      A, 13")
             (%f8-store-a-via-dc0 out))
           (progn
             (format out "~&~10tLR      A, 12")
             (%f8-store-a-via-dc0 out))))
      (t (format out "~&~10t;; Unsupported store to ~s" dest)))))

(defun compile-f8-move (out stmt class-id slot-table const-table pic-width-table)
  (let* ((from (getf (rest stmt) :from))
         (to (getf (rest stmt) :to))
         (fw (operand-width from pic-width-table))
         (tw (operand-width to pic-width-table))
         (word-result-p (= (max (or fw 1) (or tw 1)) 2)))
    (compile-f8-load out from class-id slot-table const-table pic-width-table (if word-result-p 2 1))
    (%f8-store-dest out class-id slot-table const-table to pic-width-table word-result-p)))

(defun compile-f8-invoke (out stmt class-id slot-table type-table const-table pic-width-table)
  (let ((object (getf (rest stmt) :object))
        (method (getf (rest stmt) :method))
        (returning (getf (rest stmt) :returning)))
    (let ((method-sym (f8-symbol (format nil "~a" method))))
      (cond
        ((member object '(:self "Self" self) :test #'equal)
         (format out "~&~10tPI      Invoke~a~a" (f8-symbol class-id) method-sym))
        (t
         (let* ((obj-name (f8-symbol (format nil "~a" object)))
                (obj-class (or (var-class obj-name) "Unknown")))
           (format out "~&~10tPI      Call~a~a" obj-class method-sym)))))
    (when returning
      (let ((rw (operand-width returning pic-width-table)))
        (%f8-store-dest out class-id slot-table const-table returning pic-width-table (= (or rw 1) 2))))))

(defun compile-f8-call (out stmt)
  (let ((target (getf (rest stmt) :target))
        (service (getf (rest stmt) :service)))
    (format out "~&~10tPI      ~a" (f8-symbol (format nil "~a" (or service target))))))

(defvar *f8-label* 0)

(defun f8-label (prefix)
  (format nil "_~a~d" prefix (incf *f8-label*)))

(defun %f8-emit-16bit-zero-test (out skip-label)
  (format out "~&~10tLR      A, 10")
  (format out "~&~10tCI      0")
  (format out "~&~10tBNZ     ~a" skip-label)
  (format out "~&~10tLR      A, 11")
  (format out "~&~10tCI      0")
  (format out "~&~10tBNZ     ~a" skip-label))

(defun compile-f8-if (out stmt class-id slot-table type-table const-table pic-size-table pic-width-table)
  (let ((condition (getf (rest stmt) :condition))
        (then-stmts (getf (rest stmt) :then))
        (else-stmts (getf (rest stmt) :else))
        (lbl-else (f8-label "else"))
        (lbl-end (f8-label "end")))
    (compile-f8-condition out condition class-id slot-table type-table const-table pic-width-table lbl-else)
    (dolist (s (ensure-list then-stmts))
      (compile-f8-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table))
    (when (and else-stmts (not (null else-stmts)))
      (format out "~&~10tJMP     ~a" lbl-end))
    (format out "~&~a:" lbl-else)
    (when (and else-stmts (not (null else-stmts)))
      (dolist (s (ensure-list else-stmts))
        (compile-f8-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table))
      (format out "~&~a:" lbl-end))))

(defun compile-f8-condition (out condition class-id slot-table type-table const-table pic-width-table branch-label)
  (cond
    ((and (listp condition) (member (first condition) '(= equal < less > greater) :test #'eq))
     (let ((lhs (second condition))
           (rhs (third condition))
           (op (first condition))
           (w (max (or (operand-width lhs pic-width-table) 1)
                   (or (operand-width rhs pic-width-table) 1))))
             (if (= w 2)
           (progn
             (compile-f8-load out lhs class-id slot-table const-table pic-width-table 2)
             (format out "~&~10tLR      12, 10")
             (format out "~&~10tLR      13, 11")
             (compile-f8-load out rhs class-id slot-table const-table pic-width-table 2)
             (%f8-negate-16-10 out)
             (%f8-add-16 out)
             (ecase op
               ((= equal)
                (format out "~&~10tLR      A, 10")
                (format out "~&~10tCI      0")
                (format out "~&~10tBNZ     ~a" branch-label)
                (format out "~&~10tLR      A, 11")
                (format out "~&~10tCI      0")
                (format out "~&~10tBNZ     ~a" branch-label))
               ((< less)
                (format out "~&~10tLR      A, 11")
                (format out "~&~10tBM      ~a" branch-label))
               ((> greater)
                (format out "~&~10tLR      A, 11")
                (format out "~&~10tBZ      ~a" branch-label)
                (format out "~&~10tBP      ~a" branch-label))))
           (progn
             (compile-f8-load out lhs class-id slot-table const-table pic-width-table 1)
             (format out "~&~10tLR      8, A")
             (compile-f8-load out rhs class-id slot-table const-table pic-width-table 1)
             (ecase op
               ((= equal)
                (format out "~&~10tXS      8")
                (format out "~&~10tBNZ     ~a" branch-label))
               ((< less)
                (format out "~&~10tLR      9, A")
                (format out "~&~10tLR      A, 8")
                (format out "~&~10tCOM")
                (format out "~&~10tINC")
                (format out "~&~10tAS      9")
                (format out "~&~10tBM      ~a" branch-label))
               ((> greater)
                (format out "~&~10tLR      9, A")
                (format out "~&~10tLR      A, 8")
                (format out "~&~10tCOM")
                (format out "~&~10tINC")
                (format out "~&~10tAS      9")
                (format out "~&~10tBZ      ~a" branch-label)
                (format out "~&~10tBP      ~a" branch-label)))))))
    ((and (listp condition) (eq (first condition) :is-zero))
     (let ((ex (second condition))
           (w (operand-width ex pic-width-table)))
       (compile-f8-load out ex class-id slot-table const-table pic-width-table)
       (if (= (or w 1) 2)
           (%f8-emit-16bit-zero-test out branch-label)
           (progn
             (format out "~&~10tCI      0")
             (format out "~&~10tBNZ     ~a" branch-label)))))
    ((and (listp condition) (eq (first condition) :is-not-zero))
     (let ((ex (second condition))
           (w (operand-width ex pic-width-table)))
       (compile-f8-load out ex class-id slot-table const-table pic-width-table)
       (if (= (or w 1) 2)
           (let ((sk (f8-label "snz")))
             (format out "~&~10tLR      A, 10")
             (format out "~&~10tCI      0")
             (format out "~&~10tBNZ     ~a" sk)
             (format out "~&~10tLR      A, 11")
             (format out "~&~10tCI      0")
             (format out "~&~10tBZ      ~a" branch-label)
             (format out "~&~a:" sk))
           (progn
             (format out "~&~10tCI      0")
             (format out "~&~10tBZ      ~a" branch-label)))))
    ((and (listp condition) (eq (first condition) :and))
     (compile-f8-condition out (second condition) class-id slot-table type-table const-table pic-width-table branch-label)
     (compile-f8-condition out (third condition) class-id slot-table type-table const-table pic-width-table branch-label))
    ((and (listp condition) (eq (first condition) :or))
     (let ((lbl-cond2 (f8-label "or"))
           (lbl-skip (f8-label "skip")))
       (compile-f8-condition out (second condition) class-id slot-table type-table const-table pic-width-table lbl-cond2)
       (format out "~&~10tJMP     ~a" lbl-skip)
       (format out "~&~a:" lbl-cond2)
       (compile-f8-condition out (third condition) class-id slot-table type-table const-table pic-width-table branch-label)
       (format out "~&~a:" lbl-skip)))
    (t (error "EIGHTBOL: condition ~s not implemented" condition))))

(defun f8-value (expr &optional const-table)
  (declare (ignore const-table))
  (cond
    ((numberp expr) (format nil "~d" expr))
    ((and (stringp expr) (constant-p expr))
     (format nil "~d" (constant-value expr)))
    ((stringp expr) (f8-symbol expr))
    ((eq expr :self) "Self")
    ((and (listp expr) (eq (first expr) :of))
     (f8-symbol (format nil "~a-~a" (third expr) (second expr))))
    (t (format nil "~a" expr))))

(defun f8-expr-is-constant-p (expr &optional const-table)
  "True if EXPR is a numeric literal or EIGHTBOL constant (PER CONST-TABLE).

CONST-TABLE is reserved for API alignment with other backends; detection
uses @code{constant-p} on EXPR only."
  (declare (ignore const-table))
  (or (numberp expr)
      (and (stringp expr) (constant-p expr))))

(defun compile-f8-evaluate (out stmt class-id slot-table type-table const-table pic-size-table pic-width-table)
  (let ((subject (getf (rest stmt) :subject))
        (clauses (getf (rest stmt) :when-clauses))
        (lbl-end (f8-label "eval")))
    (dolist (clause (ensure-list clauses))
      (cond
        ((eq (first clause) :when-other)
         (dolist (s (ensure-list (second clause)))
           (compile-f8-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table)))
        ((eq (first clause) :when)
         (let ((phrases (second clause))
               (stmts (third clause))
               (lbl-next (f8-label "when")))
           (cond
             ((eq phrases 'eightbol::any)
              (dolist (s (ensure-list stmts))
                (compile-f8-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table))
              (format out "~&~10tJMP     ~a" lbl-end))
             ((or (eq phrases 'eightbol::true) (equal phrases "TRUE"))
              (let ((subj-w (operand-width subject pic-width-table))
                    (edo (f8-label "etr")))
                (compile-f8-load out subject class-id slot-table const-table pic-width-table)
                (if (= (or subj-w 1) 2)
                    (progn
                      (format out "~&~10tLR      A, 10")
                      (format out "~&~10tCI      0")
                      (format out "~&~10tBNZ     ~a" edo)
                      (format out "~&~10tLR      A, 11")
                      (format out "~&~10tCI      0")
                      (format out "~&~10tBZ      ~a" lbl-next)
                      (format out "~&~a:" edo))
                    (progn
                      (format out "~&~10tCI      0")
                      (format out "~&~10tBZ      ~a" lbl-next))))
                (dolist (s (ensure-list stmts))
                  (compile-f8-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table))
                (format out "~&~10tJMP     ~a" lbl-end)
                (format out "~&~a:" lbl-next))
             ((or (and (symbolp phrases) (string= (symbol-name phrases) "FALSE"))
                  (equal phrases "FALSE"))
              (let ((subj-w (operand-width subject pic-width-table)))
                (compile-f8-load out subject class-id slot-table const-table pic-width-table)
                (if (= (or subj-w 1) 2)
                    (progn
                      (format out "~&~10tLR      A, 10")
                      (format out "~&~10tCI      0")
                      (format out "~&~10tBNZ     ~a" lbl-next)
                      (format out "~&~10tLR      A, 11")
                      (format out "~&~10tCI      0")
                      (format out "~&~10tBNZ     ~a" lbl-next))
                    (progn
                      (format out "~&~10tCI      0")
                      (format out "~&~10tBNZ     ~a" lbl-next))))
                (dolist (s (ensure-list stmts))
                  (compile-f8-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table))
                (format out "~&~10tJMP     ~a" lbl-end)
                (format out "~&~a:" lbl-next))
             ((and (listp phrases) (eq (first phrases) :not))
              (compile-f8-load out subject class-id slot-table const-table pic-width-table)
              (format out "~&~10tLR      8, A")
              (compile-f8-load out (second phrases) class-id slot-table const-table pic-width-table)
              (format out "~&~10tXS      8")
              (format out "~&~10tCI      0")
              (format out "~&~10tBZ      ~a" lbl-next)
              (dolist (s (ensure-list stmts))
                (compile-f8-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table))
              (format out "~&~10tJMP     ~a" lbl-end)
              (format out "~&~a:" lbl-next))
             ((and (listp phrases) (member (first phrases) '(:through :thru)))
              (let ((lo (second phrases)) (hi (third phrases))
                    (szw (max (or (operand-width subject pic-width-table) 1)
                              (or (operand-width lo pic-width-table) 1)
                              (or (operand-width hi pic-width-table) 1))))
                (compile-f8-load out subject class-id slot-table const-table pic-width-table)
                (when (= szw 2)
                  (format out "~&~10tLR      8, 10")
                  (format out "~&~10tLR      9, 11"))
                (when (= szw 1)
                  (format out "~&~10tLR      8, A"))
                (compile-f8-load out lo class-id slot-table const-table pic-width-table)
                ;; unsigned range reject simplification: compare low words only if szw=2 — minimal tests use small values
                (when (= szw 2)
                  (format out "~&~10t;; | EVALUATE THROUGH: 16-bit compare simplified"))
                (format out "~&~10tLR      9, A")
                (format out "~&~10tLR      A, 8")
                (format out "~&~10tCOM")
                (format out "~&~10tINC")
                (format out "~&~10tAS      9")
                (format out "~&~10tBM      ~a" lbl-next)
                (compile-f8-load out hi class-id slot-table const-table pic-width-table)
                (format out "~&~10tLR      9, A")
                (format out "~&~10tLR      A, 8")
                (format out "~&~10tCOM")
                (format out "~&~10tINC")
                (format out "~&~10tAS      9")
                (format out "~&~10tBP      ~a" lbl-next)
                (dolist (s (ensure-list stmts))
                  (compile-f8-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table))
                (format out "~&~10tJMP     ~a" lbl-end)
                (format out "~&~a:" lbl-next)))
             (t
              (let ((phrase-expr (if (listp phrases) (second phrases) phrases))
                    (szw (max (or (operand-width subject pic-width-table) 1)
                              (or (operand-width phrase-expr pic-width-table) 1))))
                (compile-f8-load out subject class-id slot-table const-table pic-width-table)
                (when (= szw 2)
                  (format out "~&~10tLR      12, 10")
                  (format out "~&~10tLR      13, 11"))
                (when (= szw 1)
                  (format out "~&~10tLR      8, A"))
                (compile-f8-load out phrase-expr class-id slot-table const-table pic-width-table)
                (if (= szw 2)
                    (progn
                      (format out "~&~10tLR      A, 10")
                      (format out "~&~10tXS      12")
                      (format out "~&~10tBNZ     ~a" lbl-next)
                      (format out "~&~10tLR      A, 11")
                      (format out "~&~10tXS      13")
                      (format out "~&~10tBNZ     ~a" lbl-next))
                    (progn
                      (format out "~&~10tXS      8")
                      (format out "~&~10tBNZ     ~a" lbl-next)))
                (dolist (s (ensure-list stmts))
                  (compile-f8-statement out s class-id slot-table type-table const-table pic-size-table pic-width-table))
                (format out "~&~10tJMP     ~a" lbl-end)
                (format out "~&~a:" lbl-next))))))))
    (format out "~&~a:" lbl-end)))

(defun compile-f8-inspect (out stmt class-id slot-table const-table pic-size-table pic-width-table)
  (let ((target (getf (rest stmt) :target))
        (tally (getf (rest stmt) :tallying))
        (conv-from (getf (rest stmt) :converting))
        (conv-to (getf (rest stmt) :to))
        (repl-by (getf (rest stmt) :by)))
    (let ((tgt-sym (f8-symbol (format nil "~a" target))))
      (cond
        (tally
         (let ((tally-sym (f8-symbol (format nil "~a" tally))))
           (format out "~&~10t;; INSPECT ~a TALLYING ~a" target tally)
           (format out "~&~10tDCI     ~a" tgt-sym)
           (format out "~&~10tLR      Q, DC0")
           (let ((lbl (f8-label "tly")) (lbl-done (f8-label "tld")))
             (format out "~&~a:" lbl)
             (format out "~&~10tLR      DC0, Q")
             (%f8-load-byte-at-dc0 out)
             (format out "~&~10tLR      9, A")
             (format out "~&~10tLR      Q, DC0")
             (format out "~&~10tLR      A, 9")
             (format out "~&~10tCI      0")
             (format out "~&~10tBZ      ~a" lbl-done)
             (format out "~&~10tDCI     ~a" tally-sym)
             (%f8-load-byte-at-dc0 out)
             (format out "~&~10tINC")
             (format out "~&~10tLR      8, A")
             (format out "~&~10tDCI     ~a" tally-sym)
             (format out "~&~10tLR      A, 8")
             (%f8-store-a-via-dc0 out)
             (format out "~&~10tBR      ~a" lbl)
             (format out "~&~a:" lbl-done))))
        (conv-from
         (format out "~&~10t;; INSPECT ~a CONVERTING" target)
         (format out "~&~10tDCI     ~a" tgt-sym)
         (format out "~&~10tLR      Q, DC0")
         (let ((lbl (f8-label "ins")) (lbl-next (f8-label "inn")) (lbl-done (f8-label "ind")))
           (format out "~&~a:" lbl)
           (format out "~&~10tLR      DC0, Q")
           (%f8-load-byte-at-dc0 out)
           (format out "~&~10tLR      9, A")
           (format out "~&~10tLR      Q, DC0")
           (format out "~&~10tLR      A, 9")
           (format out "~&~10tCI      0")
           (format out "~&~10tBZ      ~a" lbl-done)
           (if (f8-expr-is-constant-p conv-from)
               (format out "~&~10tCI      ~a" (f8-value conv-from))
               (progn
                 (format out "~&~10tLR      8, A")
                 (compile-f8-load out conv-from class-id slot-table const-table pic-width-table 1)
                 (format out "~&~10tXS      8")))
           (format out "~&~10tBNZ     ~a" lbl-next)
           (compile-f8-load out conv-to class-id slot-table const-table pic-width-table 1)
           (format out "~&~10tLR      DC0, Q")
           (format out "~&~10tLI      255")
           (format out "~&~10tADC")
           (%f8-store-a-via-dc0 out)
           (format out "~&~10tLR      Q, DC0")
           (format out "~&~10tBR      ~a" lbl)
           (format out "~&~a:" lbl-next)
           (format out "~&~10tBR      ~a" lbl)
           (format out "~&~a:" lbl-done)))
        (repl-by
         (let ((len (or (gethash (format nil "~a" target) pic-size-table) 64)))
           (format out "~&~10t;; INSPECT ~a REPLACING" target)
           (compile-f8-load out repl-by class-id slot-table const-table pic-width-table 1)
           (format out "~&~10tDCI     ~a" tgt-sym)
           (format out "~&~10tLI      ~d" len)
           (format out "~&~10tLR      6, A")
           (let ((lbl (f8-label "irp")))
             (format out "~&~a:" lbl)
             (%f8-store-a-via-dc0 out)
             (format out "~&~10tDS      6")
             (format out "~&~10tLR      A, 6")
             (format out "~&~10tCI      0")
             (format out "~&~10tBNZ     ~a" lbl))))))))

(defun %f8-add-16 (out)
  "10:11 += 12:13 (unsigned with carry)."
  (format out "~&~10tLR      A, 10")
  (format out "~&~10tAS      12")
  (format out "~&~10tLR      10, A")
  (format out "~&~10tLR      A, 11")
  (format out "~&~10tLNK")
  (format out "~&~10tAS      13")
  (format out "~&~10tLR      11, A"))

(defun %f8-negate-16-10 (out)
  "Two's complement negate 10:11 in place."
  (let ((sk (f8-label "f8n")))
    (format out "~&~10tLR      A, 10")
    (format out "~&~10tCOM")
    (format out "~&~10tINC")
    (format out "~&~10tLR      10, A")
    (format out "~&~10tLR      A, 10")
    (format out "~&~10tCI      0")
    (format out "~&~10tBNZ     ~a" sk)
    (format out "~&~10tDS      11")
    (format out "~&~a:" sk)
    (format out "~&~10tLR      A, 11")
    (format out "~&~10tCOM")
    (format out "~&~10tINC")
    (format out "~&~10tLR      11, A")))

(defun compile-f8-add (out stmt class-id slot-table const-table pic-width-table)
  (let* ((from (getf (rest stmt) :from))
         (to (getf (rest stmt) :to))
         (giving (getf (rest stmt) :giving))
         (result (or giving (and (stringp to) to)))
         (w (operand-width (or result to) pic-width-table))
         (bcd-p (when result (usage-bcd-p (expr-to-width-name result)))))
    (if (= (or w 1) 2)
        (progn
          (compile-f8-load out to class-id slot-table const-table pic-width-table 2)
          (format out "~&~10tLR      12, 10")
          (format out "~&~10tLR      13, 11")
          (compile-f8-load out from class-id slot-table const-table pic-width-table 2)
          (if bcd-p
              (format out "~&~10t;; | BCD 16-bit ADD — use AMD/ASD sequence per runtime")
              (%f8-add-16 out))
          (when result
            (%f8-store-dest out class-id slot-table const-table result pic-width-table t)))
        (progn
          (compile-f8-load out to class-id slot-table const-table pic-width-table 1)
          (format out "~&~10tLR      8, A")
          (compile-f8-load out from class-id slot-table const-table pic-width-table 1)
          (if bcd-p
              (format out "~&~10tASD     8")
              (format out "~&~10tAS      8"))
          (let ((dest (or giving (and (stringp to) to))))
            (when dest
              (%f8-store-dest out class-id slot-table const-table dest pic-width-table nil)))))))

(defun compile-f8-subtract (out stmt class-id slot-table const-table pic-width-table)
  (let* ((from (getf (rest stmt) :from))
         (from-target (getf (rest stmt) :from-target))
         (giving (getf (rest stmt) :giving))
         (dest (or giving from-target))
         (w (operand-width dest pic-width-table))
         (bcd-p (when dest (usage-bcd-p (expr-to-width-name dest)))))
    (if (= (or w 1) 2)
        (progn
          (compile-f8-load out from-target class-id slot-table const-table pic-width-table 2)
          (format out "~&~10tLR      12, 10")
          (format out "~&~10tLR      13, 11")
          (compile-f8-load out from class-id slot-table const-table pic-width-table 2)
          (unless bcd-p
            (%f8-negate-16-10 out)
            (%f8-add-16 out))
          (when bcd-p (format out "~&~10t;; | BCD 16-bit SUB — deferred"))
          (%f8-store-dest out class-id slot-table const-table dest pic-width-table t))
        (progn
          (compile-f8-load out from-target class-id slot-table const-table pic-width-table 1)
          (format out "~&~10tLR      8, A")
          (compile-f8-load out from class-id slot-table const-table pic-width-table 1)
          (format out "~&~10tCOM")
          (format out "~&~10tINC")
          (format out "~&~10tAS      8")
          (when bcd-p (format out "~&~10t;; | BCD byte subtract — deferred"))
          (%f8-store-dest out class-id slot-table const-table dest pic-width-table nil)))))

(defun compile-f8-compute (out stmt class-id slot-table const-table pic-width-table)
  (let* ((target (getf (rest stmt) :target))
         (expr (getf (rest stmt) :expression))
         (w (operand-width target pic-width-table)))
    (compile-f8-load out expr class-id slot-table const-table pic-width-table w)
    (%f8-store-dest out class-id slot-table const-table target pic-width-table (= (or w 1) 2))))

(defun compile-f8-set (out stmt class-id slot-table const-table pic-width-table)
  (let ((target (getf (rest stmt) :target))
        (value (getf (rest stmt) :value))
        (up-by (getf (rest stmt) :up-by))
        (down-by (getf (rest stmt) :down-by))
        (by-expr (getf (rest stmt) :by))
        (address-of (getf (rest stmt) :address-of))
        (to-self (getf (rest stmt) :to-self)))
    (cond
      (up-by
       (compile-f8-add out (list :add :from by-expr :to up-by :giving nil)
                       class-id slot-table const-table pic-width-table))
      (down-by
       (compile-f8-subtract out (list :subtract :from by-expr :from-target down-by :giving nil)
                            class-id slot-table const-table pic-width-table))
      ((and address-of target)
       (let ((src address-of) (dest target))
         (cond
           ((slot-of-self-p src)
            (%f8-self-pointer-to-dc0 out)
            (%f8-dc0-add-slot-offset out (second (slot-of-expr src)) class-id)
            (%f8-dc0-to-10-11 out))
           ((stringp src)
            (format out "~&~10tDCI     ~a" (slot-symbol src class-id))
            (%f8-dc0-to-10-11 out))
           (t (error "EIGHTBOL: unsupported SET ADDRESS OF source ~s for F8" src)))
         (%f8-store-dest out class-id slot-table const-table dest pic-width-table t)))
      (to-self
       (%f8-self-pointer-to-dc0 out)
       (%f8-store-dest out class-id slot-table const-table to-self pic-width-table t))
      (t
       (compile-f8-load out value class-id slot-table const-table pic-width-table)
       (%f8-store-dest out class-id slot-table const-table target pic-width-table nil)))))

(defun compile-f8-perform (out stmt class-id slot-table type-table const-table pic-width-table)
  (let ((proc (getf (rest stmt) :procedure))
        (times (getf (rest stmt) :times))
        (until (getf (rest stmt) :until)))
    (cond
      (times
       (let ((lbl (f8-label "perf"))
             (done (f8-label "pfd"))
             (tw (operand-width times pic-width-table)))
         (compile-f8-load out times class-id slot-table const-table pic-width-table)
         (if (= (or tw 1) 2)
             (progn
               (format out "~&~10tLR      6, 10")
               (format out "~&~10t;; | PERFORM count in 6 (lo) only if word — simplify"))
             (format out "~&~10tLR      6, A"))
         (format out "~&~a:" lbl)
         (format out "~&~10tLR      A, 6")
         (format out "~&~10tCI      0")
         (format out "~&~10tBZ      ~a" done)
         (format out "~&~10tPI      ~a" (f8-symbol (format nil "~a" proc)))
         (format out "~&~10tDS      6")
         (format out "~&~10tBR      ~a" lbl)
         (format out "~&~a:" done)))
      (until
       (let ((lbl-loop (f8-label "uloop"))
             (lbl-end (f8-label "uend")))
         (format out "~&~a:" lbl-loop)
         (compile-f8-condition out until class-id slot-table type-table const-table pic-width-table lbl-end)
         (format out "~&~10tPI      ~a" (f8-symbol (format nil "~a" proc)))
         (format out "~&~10tBR      ~a" lbl-loop)
         (format out "~&~a:" lbl-end)))
      (t
       (format out "~&~10tPI      ~a" (f8-symbol (format nil "~a" proc)))))))

(defun %f8-string-operand-length-expr (source stmt)
  "Return length expression for STRING BLT from STMT or SOURCE :refmod.

@table @asis
@item STMT
@code{:string-blt} statement; use @code{(rest stmt)} for the plist.
@item SOURCE
@code{:source} operand — for @code{:refmod}, read @code{:length} from @code{(cdr source)} with @code{safe-getf}.
@end table

Same rule as @code{string-operand-length-expr} / @code{%z80-string-operand-length-expr}: do not @code{getf} on the full @code{(:refmod ...)} cell."
  (or (safe-getf (rest stmt) :length)
      (when (and (listp source) (eq (first source) :refmod))
        (safe-getf (rest source) :length))))

(defun f8-string-operand-address (operand)
  (cond
    ((and (listp operand) (eq (first operand) :refmod))
     (let* ((base (getf (rest operand) :base))
            (start (getf (rest operand) :start))
            (base-str (f8-symbol (format nil "~a" base))))
       (if (and (integerp start) (= start 1))
           base-str
           (format nil "~a+~d" base-str (1- start)))))
    (t (f8-symbol (format nil "~a" operand)))))

(defun compile-f8-string-blt (out stmt class-id slot-table const-table)
  "Emit F8 STRING block copy (DELIMITED BY SIZE). Uses scratch 7 as count.

OUT, STMT, CLASS-ID, SLOT-TABLE, CONST-TABLE follow other @code{compile-f8-*} routines.
Length from @code{:length}, SOURCE @code{:refmod}, or DEST @code{:refmod} via
@code{%f8-string-operand-length-expr}; non-constant length defaults to 64."
  (declare (ignore slot-table))
  (let* ((source (safe-getf (rest stmt) :source))
         (dest (safe-getf (rest stmt) :dest))
         (len-expr (or (%f8-string-operand-length-expr source stmt)
                       (when (and (listp dest) (eq (first dest) :refmod))
                         (safe-getf (rest dest) :length))))
         (len (cond ((integerp len-expr) len-expr)
                    ((and len-expr (f8-expr-is-constant-p len-expr const-table))
                     (if (numberp len-expr)
                         len-expr
                         (constant-value len-expr)))
                    (t 64))))
    (let ((src-addr (f8-string-operand-address source))
          (dst-addr (f8-string-operand-address dest))
          (lbl (f8-label "blt"))
          (done (f8-label "bld")))
      (format out "~&~10t;; STRING BLT ~d bytes ~a -> ~a" len src-addr dst-addr)
      (format out "~&~10tLI      ~d" len)
      (format out "~&~10tLR      7, A")
      (format out "~&~10tDCI     ~a" src-addr)
      (format out "~&~10tLR      Q, DC0")
      (format out "~&~10tDCI     ~a" dst-addr)
      (format out "~&~10tLR      DC0, H")
      (format out "~&~a:" lbl)
      (format out "~&~10tLR      A, 7")
      (format out "~&~10tCI      0")
      (format out "~&~10tBZ      ~a" done)
      (format out "~&~10tLR      DC0, Q")
      (%f8-load-byte-at-dc0 out)
      (format out "~&~10tLR      8, A")
      (format out "~&~10tLR      Q, DC0")
      (format out "~&~10tLR      H, DC0")
      (format out "~&~10tLR      A, 8")
      (%f8-store-a-via-dc0 out)
      (format out "~&~10tLR      DC0, H")
      (format out "~&~10tDS      7")
      (format out "~&~10tBR      ~a" lbl)
      (format out "~&~a:" done))))
